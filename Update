CREATE TABLE EquipmentModel (
    equipmentModelId   INTEGER PRIMARY KEY,
    typeEquipmentId    INTEGER,
    shortNameEquipment TEXT,
    fullNameEquipment  TEXT,
    mnemonicName       TEXT,
    Manufacturer       TEXT,
    UnitPressure       TEXT,
    absolutePressure   INTEGER,
    UnitVolume         TEXT,
    VolumeCC           REAL
);

CREATE TABLE EquipmentUnit (
    equipmentUnitId    INTEGER PRIMARY KEY,
    equipmentModelId   INTEGER,
    serialNumber       TEXT,
    inventoryNumber    TEXT,
    shortNumber        TEXT,
    status             TEXT,
    CellFactor         REAL,
    UnitPressure       TEXT,
    absolutePressure   INTEGER,
    UnitVolume         TEXT,
    VolumeCC           REAL,

    FOREIGN KEY (equipmentModelId)
        REFERENCES EquipmentModel(equipmentModelId)
);
