Вставь целиком в **Расширенный редактор** вместо текущего кода:

```powerquery
let
    #"Измененный тип" = Table.TransformColumnTypes(
        TaskStatus_Table,
        {
            {"statusid", Int64.Type},
            {"status", type text},
            {"taskid", Int64.Type},
            {"task_type", type text},
            {"resultId", Int64.Type},
            {"dateTime", type datetime}
        }
    ),

    #"Сортировка по statusid" = Table.Sort(
        #"Измененный тип",
        {
            {"statusid", Order.Descending}
        }
    ),

    #"Буферизация таблицы" = Table.Buffer(
        #"Сортировка по statusid"
    ),

    #"Удаление дубликатов taskid" = Table.Distinct(
        #"Буферизация таблицы",
        {
            "taskid"
        }
    )
in
    #"Удаление дубликатов taskid"
```

Для каждого `taskid` останется одна строка с наибольшим `statusid`.
