Private Function getLastFormNumberOPOH() As Long
    
    Dim i As Long
    Dim cellSampleCode As Range
    
    Dim sheetOPOH As Worksheet
    Set sheetOPOH = ActiveWorkbook.Worksheets("OPOH")
    
    Dim wb As Workbook
    Set wb = ActiveWorkbook
    
    i = 2
    Do While NamedRangeExists(wb, "OPOH_" & i & "_sampleCode")
        i = i + 1
    Loop
    getLastFormNumberOPOH = i - 1
End Function


Sub InsertFormOPOH()

    Dim sheetOPOH As Worksheet
    Set sheetOPOH = ActiveWorkbook.Worksheets("OPOH")
    Dim sheetOPOH_result As Worksheet
    Set sheetOPOH_result = ActiveWorkbook.Worksheets("OPOH_results")
    
    Dim wb As Workbook
    Set wb = ActiveWorkbook

    Dim lastList As Long
    Dim lastColumn As Long
    Dim firstColumn As Long
    Dim lenght As Long

    lenght = sheetOPOH.Range("OPOH_2_sampleCode").Column - sheetOPOH.Range("OPOH_1_sampleCode").Column
    lastList = getLastFormNumberOPOH() + 1

    lastColumn = lastList * lenght + OPOH_FIRST_FORM_FIRST_COL - 1
    firstColumn = lastColumn - lenght + 1

    sheetOPOH.Activate

    Dim oldCopyObjectsWithCells As Boolean
    oldCopyObjectsWithCells = Application.CopyObjectsWithCells
    
    Application.CopyObjectsWithCells = False
    
    sheetOPOH.Activate
    
    sheetOPOH.Range( _
        sheetOPOH.columns(firstColumn - lenght), _
        sheetOPOH.columns(lastColumn - lenght) _
    ).EntireColumn.Copy
    
    sheetOPOH.columns(firstColumn).PasteSpecial Paste:=xlPasteAll
    sheetOPOH.columns(firstColumn).PasteSpecial Paste:=xlPasteColumnWidths
    
    Application.CutCopyMode = False
    Application.CopyObjectsWithCells = oldCopyObjectsWithCells
    
    ' Номер страницы
    sheetOPOH.Cells(OPOH_PAGE_ROW, firstColumn + OPOH_PAGE_FIRST_COL - OPOH_FIRST_FORM_FIRST_COL).value = lastList
    
    CreateOPOHNamesForNewForm wb, sheetOPOH, lastList - 1, lastList, lenght
    
    createFormCheckBoxes lastList
    
End Sub

Public Sub DeleteLastListOPOH()
    
    Dim sheetOPOH As Worksheet
    Set sheetOPOH = ActiveWorkbook.Worksheets("OPOH")
    
    Dim sheetOPOHresults As Worksheet
    Set sheetOPOHresults = ActiveWorkbook.Worksheets("OPOH_results")
    
    Dim tableResults As ListObject
    Set tableResults = sheetOPOHresults.ListObjects("OPOH_results")
    
    Dim lastForm As Long
    lastForm = getLastFormNumberOPOH()
    
    If lastForm <= 2 Then
        MsgBox "Нельзя удалить 2 первые формы"
        Exit Sub
    End If
    
    Dim countFormCols As Long
    countFormCols = sheetOPOH.Range("OPOH_2_sampleCode").Column - sheetOPOH.Range("OPOH_1_sampleCode").Column
    
    Dim firstColLastForm As Long
    firstColLastForm = OPOH_FIRST_FORM_FIRST_COL + (lastForm - 1) * countFormCols
    
    Dim lastColLastForm As Long
    lastColLastForm = firstColLastForm + countFormCols - 1
    
    Dim headerCell As Range
    Dim namedRange As String
    
    For Each headerCell In tableResults.HeaderRowRange.Cells
        namedRange = "OPOH_" & lastForm & "_" & CStr(headerCell.value)
        
        If NamedRangeExists(ActiveWorkbook, namedRange) Then
            ActiveWorkbook.Names(namedRange).Delete
        End If
    Next headerCell
    
    sheetOPOH.Range( _
        sheetOPOH.columns(firstColLastForm), _
        sheetOPOH.columns(lastColLastForm) _
    ).EntireColumn.Delete
    
    Call DeleteCheckBoxesFromColumnRight(sheetOPOH, firstColLastForm)

End Sub

Private Sub createFormCheckBoxes(ByVal formIndex As Long)
    
    Dim sheetOPOH As Worksheet
    Set sheetOPOH = ActiveWorkbook.Worksheets("OPOH")
    
    Dim sheetOPOH_result As Worksheet
    Set sheetOPOH_result = ActiveWorkbook.Worksheets("OPOH_results")
    
    Dim resultTable As ListObject
    Set resultTable = sheetOPOH_result.ListObjects("OPOH_results")
    
    Dim wb As Workbook
    Set wb = ActiveWorkbook
    
    Dim headCell As Range
    Dim name As String
    Dim cb As CheckBox
    Dim linkedCell As Range
    Dim area As Range
    
    For Each headCell In resultTable.HeaderRowRange
        If headCell.value Like "*Pabs" Then
            name = "OPOH_" & formIndex & "_" & Trim$(headCell.value)
            If NamedRangeExists(wb, name) Then
                Set linkedCell = wb.Names(name).RefersToRange

                If linkedCell.MergeCells Then
                    Set area = linkedCell.MergeArea
                Else
                    Set area = linkedCell
                End If
        
                Set cb = sheetOPOH.CheckBoxes.Add( _
                    area.Left, _
                    area.Top, _
                    area.Width, _
                    area.Height _
                )
                
                With cb
                    .name = "CheckBox_OPOH_" & formIndex & "_" & headCell.value
                    .Caption = vbNullString
                    .linkedCell = "'" & sheetOPOH.name & "'!" & linkedCell.Address(False, False)
                    .value = xlOff
                    .Placement = xlMove
                End With
        
                linkedCell.value = False
            Else
                Err.Raise vbObjectError + 3101, , "не удалось найти именованный диапазон " & name
            End If
        End If
    Next headCell

End Sub

Private Sub CreateOPOHNamesForNewForm( _
    ByVal wb As Workbook, _
    ByVal ws As Worksheet, _
    ByVal oldFormNumber As Long, _
    ByVal newFormNumber As Long, _
    ByVal formLength As Long)

    Dim tableOPOHResult As ListObject
    Set tableOPOHResult = wb.Worksheets("OPOH_results").ListObjects("OPOH_results")

    Dim headerCell As Range
    Dim fieldName As String

    Dim oldName As String
    Dim newName As String

    Dim oldRange As Range
    Dim newRange As Range

    For Each headerCell In tableOPOHResult.HeaderRowRange

        fieldName = CStr(headerCell.value)

        If fieldName = vbNullString Then GoTo ContinueLoop
        If fieldName = "dateTimeSync" Then GoTo ContinueLoop

        oldName = "OPOH_" & oldFormNumber & "_" & fieldName
        newName = "OPOH_" & newFormNumber & "_" & fieldName

        Set oldRange = GetNamedRangeStrict(wb, oldName)
        Set newRange = ws.Cells(oldRange.row, oldRange.Column + formLength)

        SetWorkbookLevelName wb, newName, newRange

        ResetCopiedCell newRange, oldFormNumber, newFormNumber

ContinueLoop:
    Next headerCell

End Sub
