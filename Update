Option Explicit

Private Enum OPOHFormState
    OPOH_FORM_EMPTY = 0
    OPOH_FORM_RESERVED = 1
    OPOH_FORM_FILLED = 2
End Enum

Private Const COL_RESULT_ID_DB As String = "resultIdOPOH"
Private Const COL_TASK_ID_DB As String = "taskId"
Private Const COL_SAMPLE_CODE_DB As String = "sampleCode"
Private Const COL_DATE_TIME_SYNC_DB As String = "dateTimeSync"

Private Const OPOH_FIRST_FORM_FIRST_COL As Long = 3
Private Const OPOH_PAGE_ROW = 3
Private Const OPOH_PAGE_FIRST_COL = 3


Public Sub Validate_OPOH()
    Call Save_OPOH("Валидировано")
End Sub


Public Sub Save_OPOH(Optional ByVal taskStatus As String = "")

    Dim wb As Workbook
    Set wb = ActiveWorkbook

    Dim sheetOPOH As Worksheet
    Set sheetOPOH = wb.Worksheets("OPOH")

    Dim resultTable As ListObject
    Set resultTable = wb.Worksheets("OPOH_results").ListObjects("OPOH_results")

    Dim tasks As ListObject
    Set tasks = wb.Worksheets("Task").ListObjects(1)

    Dim resultRows As Collection
    Set resultRows = New Collection

    Dim sampleCodes As Object
    Set sampleCodes = CreateObject("Scripting.Dictionary")
    sampleCodes.CompareMode = vbTextCompare

    Dim formIndex As Long
    Dim formState As OPOHFormState

    formIndex = 1

    Do While NamedRangeExists(wb, "OPOH_" & formIndex & "_" & COL_SAMPLE_CODE_DB)

        formState = Get_OPOH_FormState(formIndex)

        Select Case formState
            Case OPOH_FORM_EMPTY, OPOH_FORM_RESERVED
                GoTo NextForm

            Case OPOH_FORM_FILLED
                ' продолжаем сохранение
        End Select

        If sheetOPOH.Range("OPOH_" & formIndex & "_" & COL_TASK_ID_DB).Interior.ColorIndex = 3 Then
            GoTo NextForm
        End If

        If Not Validate_OPOH_Form(formIndex) Then
            Exit Sub
        End If

        Dim sampleCode As String
        sampleCode = Trim$(CStr(sheetOPOH.Range( _
            "OPOH_" & formIndex & "_" & COL_SAMPLE_CODE_DB _
        ).value))

        If sampleCodes.Exists(sampleCode) Then
            MsgBox "OPOH_" & formIndex & " не сохранена." & vbCrLf & vbCrLf & _
                   "Шифр пробы " & sampleCode & " уже указан на странице " & _
                   sampleCodes(sampleCode) & ".", vbExclamation
            Exit Sub
        End If

        sampleCodes.Add sampleCode, formIndex

        Dim curTask As Variant
        curTask = sheetOPOH.Range("OPOH_" & formIndex & "_" & COL_TASK_ID_DB).value

        If Len(Trim$(CStr(curTask))) > 0 And CLng(val(curTask)) <> 0 Then
            If Not CheckOPOHTask(tasks, CLng(val(curTask)), sampleCode, formIndex) Then
                GoTo NextForm
            End If
        End If

        Dim resultIdValue As Variant
        Dim parentKey As String

        resultIdValue = sheetOPOH.Range( _
            "OPOH_" & formIndex & "_" & COL_RESULT_ID_DB _
        ).value

        If Len(NormalizeKeyValue(resultIdValue)) = 0 _
           Or NormalizeKeyValue(resultIdValue) = "0" Then
            parentKey = "temp_" & formIndex
        Else
            parentKey = NormalizeKeyValue(resultIdValue)
        End If

        Dim resultRow() As Variant
        ReDim resultRow(1 To resultTable.ListColumns.count)

        Dim headerCell As Range
        Dim headerName As String
        Dim columnIndex As Long
        Dim fieldValue As Variant

        For Each headerCell In resultTable.HeaderRowRange.Cells

            headerName = Trim$(CStr(headerCell.value))
            columnIndex = resultTable.ListColumns(headerName).index

            Select Case LCase$(headerName)

                Case "datetimesync"
                    resultRow(columnIndex) = Format$(Now, "yyyy-mm-dd hh:nn:ss")

                Case "resultidopoh"
                    resultRow(columnIndex) = parentKey

                Case Else
                    fieldValue = sheetOPOH.Range( _
                        "OPOH_" & formIndex & "_" & headerName _
                    ).value

                    If Right$(LCase$(headerName), 8) = "datetime" _
                       And Len(Trim$(CStr(fieldValue))) > 0 _
                       And IsDate(fieldValue) Then

                        resultRow(columnIndex) = Format$(CDate(fieldValue), "yyyy-mm-dd hh:nn:ss")
                    Else
                        resultRow(columnIndex) = FormatValueForSyncText(headerName, fieldValue)
                    End If

            End Select

        Next headerCell

        resultRows.Add resultRow

NextForm:
        formIndex = formIndex + 1
    Loop

    WriteCollectionToListObject resultTable, resultRows

    If resultRows.count = 0 Then
        Exit Sub
    End If

    Dim syncResult As String
    syncResult = RunStudySync("save", studies:="OPOH", taskStatus:=taskStatus)

    If InStr(1, syncResult, """ok"": true", vbTextCompare) > 0 Then
        Call Load_OPOH_results_to_forms("by_key", COL_RESULT_ID_DB)
    Else
        MsgBox "Python-синхронизация OPOH не подтвердила успешное сохранение." & _
               vbCrLf & vbCrLf & syncResult, vbExclamation
    End If

End Sub


Private Function CheckOPOHTask( _
    ByVal tasks As ListObject, _
    ByVal taskId As Long, _
    ByVal sampleCode As String, _
    ByVal pageNumber As Long _
) As Boolean

    CheckOPOHTask = False

    Dim taskCheck As Range
    Set taskCheck = tasks.ListColumns("Номер задания").DataBodyRange.Find( _
        What:=taskId, _
        LookAt:=xlWhole, _
        SearchOrder:=xlByColumns _
    )

    If taskCheck Is Nothing Then
        MsgBox "Указан неизвестный номер анализа " & taskId & _
               " на странице " & pageNumber & _
               ". Данное исследование игнорируется, попробуйте обновить данные проекта или исправьте значение."
        Exit Function
    End If

    Dim taskRowIndex As Long
    taskRowIndex = taskCheck.row - tasks.DataBodyRange.row + 1

    If CStr(tasks.ListColumns("Код проекта").DataBodyRange.Cells(taskRowIndex, 1).value) <> sampleCode Then
        MsgBox "Указан неверный номер анализа " & taskId & _
               " на странице " & pageNumber & _
               ". Шифр пробы в задании отличается от шифра пробы в исследовании. " & _
               "Данное исследование игнорируется, исправьте номер задания или выберите верную форму для внесения."
        Exit Function
    End If

    CheckOPOHTask = True

End Function


Public Sub Load_OPOH_results_to_forms( _
    Optional ByVal mode As String = "by_key", _
    Optional ByVal fields As Variant _
)

    Dim wb As Workbook
    Set wb = ActiveWorkbook

    Dim sheetOPOH As Worksheet
    Set sheetOPOH = wb.Worksheets("OPOH")

    Dim resultTable As ListObject
    Set resultTable = wb.Worksheets("OPOH_results").ListObjects("OPOH_results")

    Dim fieldFilter As Object
    Set fieldFilter = BuildFieldFilter(fields)

    mode = LCase$(Trim$(mode))

    If mode <> "by_key" And mode <> "sequential" Then
        Err.Raise vbObjectError + 6101, , "mode должен быть 'by_key' или 'sequential'"
    End If

    If resultTable.DataBodyRange Is Nothing Then
        Exit Sub
    End If

    Dim resultRowIndex As Long
    Dim formIndex As Long
    Dim notFoundCount As Long

    For resultRowIndex = 1 To resultTable.ListRows.count

        If mode = "sequential" Then
            formIndex = resultRowIndex

            Do While Not NamedRangeExists(wb, "OPOH_" & formIndex & "_" & COL_SAMPLE_CODE_DB)
                Call InsertFormOPOH
            Loop
        Else
            formIndex = FindFormIndexForResultRow( _
                wb, _
                sheetOPOH, _
                resultTable, _
                resultRowIndex, _
                "OPOH", _
                Array(COL_SAMPLE_CODE_DB) _
            )
        End If

        If formIndex = 0 _
           Or Not NamedRangeExists(wb, "OPOH_" & formIndex & "_" & COL_SAMPLE_CODE_DB) Then

            notFoundCount = notFoundCount + 1

            MsgBox "Не найдена форма для строки OPOH_results #" & resultRowIndex & vbCrLf & _
                   "sampleCode = " & GetTableValue(resultTable, resultRowIndex, COL_SAMPLE_CODE_DB) & vbCrLf & _
                   "taskId = " & GetTableValue(resultTable, resultRowIndex, COL_TASK_ID_DB), _
                   vbExclamation

            GoTo NextResultRow
        End If

        Call CopyTableRowToNamedRanges( _
            wb, _
            sheetOPOH, _
            resultTable, _
            resultRowIndex, _
            "OPOH", _
            formIndex, _
            fieldFilter _
        )

NextResultRow:
    Next resultRowIndex

    If notFoundCount > 0 Then
        MsgBox "Данные OPOH перенесены частично. Не найдено форм: " & _
               notFoundCount, vbExclamation
    End If

End Sub


Private Function Validate_OPOH_Form(ByVal formIndex As Long) As Boolean

    Validate_OPOH_Form = False

    Dim wb As Workbook
    Set wb = ActiveWorkbook

    Dim resultTable As ListObject
    Set resultTable = wb.Worksheets("OPOH_results").ListObjects("OPOH_results")

    Dim errors As String
    Dim errorCount As Long

    If formIndex <= 0 Then
        MsgBox "Некорректный номер формы OPOH: " & formIndex, vbExclamation
        Exit Function
    End If

    If Not NamedRangeExists(wb, "OPOH_" & formIndex & "_" & COL_SAMPLE_CODE_DB) Then
        MsgBox "Форма OPOH_" & formIndex & " не найдена.", vbExclamation
        Exit Function
    End If

    Dim headerCell As Range
    Dim fieldName As String
    Dim fieldNameLower As String
    Dim rangeName As String

    Dim rng As Range
    Dim valueText As String

    Dim relatedRangeName As String
    Dim relatedValue As Variant
    Dim relatedText As String

    Dim firstPressureName As String
    Dim secondPressureName As String

    Dim firstPressureValue As Variant
    Dim secondPressureValue As Variant

    Dim firstPressureText As String
    Dim secondPressureText As String

    Dim hasPressureValue As Boolean
    Dim canCheckPressureUnit As Boolean

    Dim restorationStartName As String
    Dim restorationStartValue As Variant
    Dim restorationStartText As String

    For Each headerCell In resultTable.HeaderRowRange.Cells

        fieldName = Trim$(CStr(headerCell.value))
        fieldNameLower = LCase$(fieldName)

        If fieldNameLower = "datetimesync" Then
            GoTo NextHeader
        End If

        rangeName = "OPOH_" & formIndex & "_" & fieldName

        If Not NamedRangeExists(wb, rangeName) Then

            errorCount = errorCount + 1

            errors = errors & errorCount & _
                     ". Не найден именованный диапазон: " & _
                     rangeName & vbCrLf

            GoTo NextHeader

        End If

        Set rng = wb.Names(rangeName).RefersToRange.Cells(1, 1)

        If IsError(rng.value) Then

            errorCount = errorCount + 1

            errors = errors & errorCount & _
                     ". " & rangeName & _
                     " содержит ошибку Excel: " & rng.text & _
                     " (" & rng.Worksheet.name & _
                     "!" & rng.Address(False, False) & ")" & vbCrLf

            GoTo NextHeader

        End If

        valueText = Trim$(CStr(rng.value))

        Select Case fieldNameLower

            Case "resultidopoh"
                ' До первого сохранения может быть пустым.


            Case "taskid"

                If valueText <> "" Then

                    If Not IsNumeric(rng.value) Then

                        errorCount = errorCount + 1

                        errors = errors & errorCount & _
                                 ". Номер задания должен быть числом: " & _
                                 rangeName & vbCrLf

                    ElseIf CDbl(rng.value) < 0 Then

                        errorCount = errorCount + 1

                        errors = errors & errorCount & _
                                 ". Номер задания не может быть отрицательным: " & _
                                 rangeName & vbCrLf

                    ElseIf CDbl(rng.value) <> Fix(CDbl(rng.value)) Then

                        errorCount = errorCount + 1

                        errors = errors & errorCount & _
                                 ". Номер задания должен быть целым числом: " & _
                                 rangeName & vbCrLf

                    End If

                End If


            Case "samplecode"

                If valueText = "" Then

                    errorCount = errorCount + 1

                    errors = errors & errorCount & _
                             ". Не заполнен шифр пробы: " & _
                             rangeName & vbCrLf

                End If


            Case "opendatetime"

                If valueText = "" Then

                    errorCount = errorCount + 1

                    errors = errors & errorCount & _
                             ". Не указаны дата и время открытия: " & _
                             rangeName & vbCrLf

                ElseIf Not IsDate(rng.value) Then

                    errorCount = errorCount + 1

                    errors = errors & errorCount & _
                             ". Значение невозможно преобразовать в дату и время: " & _
                             rangeName & vbCrLf

                End If


            Case "restorationstartdatetime", _
                 "restorationenddatetime", _
                 "transferdatetime", _
                 "phasedraindatetime"

                If valueText <> "" Then

                    If Not IsDate(rng.value) Then

                        errorCount = errorCount + 1

                        errors = errors & errorCount & _
                                 ". Значение невозможно преобразовать в дату и время: " & _
                                 rangeName & vbCrLf

                    End If

                End If

                relatedRangeName = ""

                Select Case fieldNameLower

                    Case "restorationstartdatetime"

                        relatedRangeName = _
                            "OPOH_" & formIndex & _
                            "_restorationStartOperator"

                    Case "restorationenddatetime"

                        relatedRangeName = _
                            "OPOH_" & formIndex & _
                            "_restorationEndOperator"

                    Case "transferdatetime"

                        relatedRangeName = _
                            "OPOH_" & formIndex & _
                            "_transferOperator"

                    Case "phasedraindatetime"

                        relatedRangeName = _
                            "OPOH_" & formIndex & _
                            "_phaseDrainOperator"

                End Select

                If NamedRangeExists(wb, relatedRangeName) Then

                    relatedValue = wb.Names(relatedRangeName) _
                        .RefersToRange.Cells(1, 1).value

                    If Not IsError(relatedValue) Then

                        relatedText = Trim$(CStr(relatedValue))

                        If valueText <> "" And relatedText = "" Then

                            errorCount = errorCount + 1

                            errors = errors & errorCount & _
                                     ". Для указанной даты и времени не указан исполнитель: " & _
                                     relatedRangeName & vbCrLf

                        ElseIf relatedText <> "" And valueText = "" Then

                            errorCount = errorCount + 1

                            errors = errors & errorCount & _
                                     ". Для указанного исполнителя не указаны дата и время: " & _
                                     rangeName & vbCrLf

                        End If

                    End If

                End If

                If fieldNameLower = "restorationenddatetime" Then

                    restorationStartName = _
                        "OPOH_" & formIndex & _
                        "_restorationStartDateTime"

                    If NamedRangeExists(wb, restorationStartName) Then

                        restorationStartValue = _
                            wb.Names(restorationStartName) _
                            .RefersToRange.Cells(1, 1).value

                        If Not IsError(restorationStartValue) Then

                            restorationStartText = _
                                Trim$(CStr(restorationStartValue))

                            If restorationStartText <> "" _
                               And valueText <> "" _
                               And IsDate(restorationStartValue) _
                               And IsDate(rng.value) Then

                                If CDate(rng.value) < _
                                   CDate(restorationStartValue) Then

                                    errorCount = errorCount + 1

                                    errors = errors & errorCount & _
                                             ". Время окончания восстановления " & _
                                             "не может быть раньше времени начала." & _
                                             vbCrLf

                                End If

                            End If

                        End If

                    End If

                End If


            Case "openoperator"

                If valueText = "" Then

                    errorCount = errorCount + 1

                    errors = errors & errorCount & _
                             ". Не указан исполнитель открытия: " & _
                             rangeName & vbCrLf

                ElseIf Not IsValidExecutor(rng.value) Then

                    errorCount = errorCount + 1

                    errors = errors & errorCount & _
                             ". Неверно указан исполнитель: " & _
                             rangeName & vbCrLf

                End If


            Case "restorationstartoperator", _
                 "restorationendoperator", _
                 "transferoperator", _
                 "phasedrainoperator"

                If valueText <> "" Then

                    If Not IsValidExecutor(rng.value) Then

                        errorCount = errorCount + 1

                        errors = errors & errorCount & _
                                 ". Неверно указан исполнитель: " & _
                                 rangeName & vbCrLf

                    End If

                End If


            Case "coldpabs", _
                 "hotpabs", _
                 "restorationpabs", _
                 "transferpabs"

                If valueText <> "" Then

                    Select Case LCase$(valueText)

                        Case "true", "false", _
                             "истина", "ложь", _
                             "1", "0", _
                             "yes", "no", _
                             "да", "нет", _
                             "+", "-"

                            ' Допустимое логическое значение.

                        Case Else

                            errorCount = errorCount + 1

                            errors = errors & errorCount & _
                                     ". Поле должно содержать логическое значение: " & _
                                     rangeName & vbCrLf

                    End Select

                End If


            Case "tcoldopen", _
                 "thotopen", _
                 "restorationt", _
                 "transfert"

                If valueText <> "" Then

                    If Not IsNumeric(rng.value) Then

                        errorCount = errorCount + 1

                        errors = errors & errorCount & _
                                 ". Температура должна быть числом: " & _
                                 rangeName & vbCrLf

                    ElseIf CDbl(rng.value) < -20 _
                           Or CDbl(rng.value) > 140 Then

                        errorCount = errorCount + 1

                        errors = errors & errorCount & _
                                 ". Температура должна быть в диапазоне " & _
                                 "от -20 до 140 °C: " & _
                                 rangeName & vbCrLf

                    End If

                End If


            Case "coldcompp", _
                 "coldexpp", _
                 "coldopenpmpaabs", _
                 "hotcompp", _
                 "hotexpp", _
                 "hotopenpmpaabs", _
                 "restorationp", _
                 "restorationpmpaabs", _
                 "transferp", _
                 "transferpmpaabs", _
                 "transfervolume", _
                 "sncvolumehc", _
                 "sncvolumedm", _
                 "sncvolumew", _
                 "flcvolumehc", _
                 "flcvolumedm", _
                 "flcvolumew"

                If valueText <> "" Then

                    If Not IsNumeric(rng.value) Then

                        errorCount = errorCount + 1

                        errors = errors & errorCount & _
                                 ". Значение должно быть числом: " & _
                                 rangeName & vbCrLf

                    ElseIf CDbl(rng.value) < 0 Then

                        errorCount = errorCount + 1

                        errors = errors & errorCount & _
                                 ". Значение не может быть отрицательным: " & _
                                 rangeName & vbCrLf

                    End If

                End If


            Case "coldpunit", _
                 "hotpunit", _
                 "restorationpunit", _
                 "transferpunit"

                firstPressureName = ""
                secondPressureName = ""

                Select Case fieldNameLower

                    Case "coldpunit"

                        firstPressureName = _
                            "OPOH_" & formIndex & "_coldCompP"

                        secondPressureName = _
                            "OPOH_" & formIndex & "_coldExpP"

                    Case "hotpunit"

                        firstPressureName = _
                            "OPOH_" & formIndex & "_hotCompP"

                        secondPressureName = _
                            "OPOH_" & formIndex & "_hotExpP"

                    Case "restorationpunit"

                        firstPressureName = _
                            "OPOH_" & formIndex & "_restorationP"

                    Case "transferpunit"

                        firstPressureName = _
                            "OPOH_" & formIndex & "_transferP"

                End Select

                canCheckPressureUnit = _
                    NamedRangeExists(wb, firstPressureName)

                If secondPressureName <> "" Then

                    canCheckPressureUnit = _
                        canCheckPressureUnit And _
                        NamedRangeExists(wb, secondPressureName)

                End If

                If canCheckPressureUnit Then

                    firstPressureValue = _
                        wb.Names(firstPressureName) _
                        .RefersToRange.Cells(1, 1).value

                    If secondPressureName <> "" Then

                        secondPressureValue = _
                            wb.Names(secondPressureName) _
                            .RefersToRange.Cells(1, 1).value

                    Else

                        secondPressureValue = Empty

                    End If

                    If Not IsError(firstPressureValue) _
                       And Not IsError(secondPressureValue) Then

                        firstPressureText = _
                            Trim$(CStr(firstPressureValue))

                        secondPressureText = _
                            Trim$(CStr(secondPressureValue))

                        hasPressureValue = False

                        If firstPressureText <> "" Then

                            If Not IsNumeric(firstPressureValue) Then

                                hasPressureValue = True

                            ElseIf CDbl(firstPressureValue) <> 0 Then

                                hasPressureValue = True

                            End If

                        End If

                        If secondPressureText <> "" Then

                            If Not IsNumeric(secondPressureValue) Then

                                hasPressureValue = True

                            ElseIf CDbl(secondPressureValue) <> 0 Then

                                hasPressureValue = True

                            End If

                        End If

                        If hasPressureValue And valueText = "" Then

                            errorCount = errorCount + 1

                            errors = errors & errorCount & _
                                     ". Для указанного давления " & _
                                     "не выбраны единицы измерения: " & _
                                     rangeName & vbCrLf

                        End If

                    End If

                End If

        End Select

NextHeader:
    Next headerCell

    If errorCount > 0 Then

        MsgBox "OPOH_" & formIndex & _
               " не сохранена. Исправьте ошибки:" & _
               vbCrLf & vbCrLf & errors, _
               vbExclamation

        Exit Function

    End If

    Validate_OPOH_Form = True

End Function


Private Function Get_OPOH_FormState(ByVal formIndex As Long) As OPOHFormState

    Dim wb As Workbook
    Set wb = ActiveWorkbook

    Dim sheetOPOH As Worksheet
    Set sheetOPOH = wb.Worksheets("OPOH")

    Dim resultTable As ListObject
    Set resultTable = wb.Worksheets("OPOH_results").ListObjects("OPOH_results")

    Dim sampleCode As String
    sampleCode = Trim$(CStr(sheetOPOH.Range( _
        "OPOH_" & formIndex & "_" & COL_SAMPLE_CODE_DB _
    ).value))

    Dim hasMeaningfulData As Boolean
    Dim headerCell As Range
    Dim fieldName As String
    Dim fieldNameLower As String
    Dim rangeName As String
    Dim rng As Range
    Dim currentValue As Variant
    Dim currentText As String

    For Each headerCell In resultTable.HeaderRowRange.Cells

        fieldName = Trim$(CStr(headerCell.value))
        fieldNameLower = LCase$(fieldName)

        Select Case fieldNameLower
            Case "resultidopoh", LCase$(COL_TASK_ID_DB), _
                 LCase$(COL_SAMPLE_CODE_DB), LCase$(COL_DATE_TIME_SYNC_DB), _
                 "coldpabs", "hotpabs", "restorationpabs", "transferpabs"
                GoTo NextStateField
        End Select

        rangeName = "OPOH_" & formIndex & "_" & fieldName

        If Not NamedRangeExists(wb, rangeName) Then
            GoTo NextStateField
        End If

        Set rng = wb.Names(rangeName).RefersToRange

        If RangeHasFormula(rng) Then
            GoTo NextStateField
        End If

        currentValue = rng.Cells(1, 1).value

        If IsError(currentValue) Then
            hasMeaningfulData = True
            Exit For
        End If

        currentText = Trim$(CStr(currentValue))

        If currentText <> "" Then
            If VarType(currentValue) = vbBoolean Then
                If CBool(currentValue) Then
                    hasMeaningfulData = True
                    Exit For
                End If
            ElseIf IsNumeric(currentValue) Then
                If CDbl(currentValue) <> 0 Then
                    hasMeaningfulData = True
                    Exit For
                End If
            Else
                hasMeaningfulData = True
                Exit For
            End If
        End If

NextStateField:
    Next headerCell

    If sampleCode = "" And Not hasMeaningfulData Then
        Get_OPOH_FormState = OPOH_FORM_EMPTY
        Exit Function
    End If

    If sampleCode <> "" And hasMeaningfulData Then
        Get_OPOH_FormState = OPOH_FORM_FILLED
        Exit Function
    End If

    Get_OPOH_FormState = OPOH_FORM_RESERVED

End Function


Public Sub Load_OPOH()
    LoadResearchesFromDB "OPOH"
