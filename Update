Public Sub cancelCurrentTaskCCE()
    
    Dim wb As Workbook
    Set wb = ActiveWorkbook

    Dim sheetCCE As Worksheet
    Set sheetCCE = wb.Worksheets("CCE")
    
    Dim lenght As Integer
    lenght = sheetCCE.Range("CCE_2_sampleCode").Column - sheetCCE.Range("CCE_1_sampleCode").Column
    
    Dim curFormIndex As Integer
    curFormIndex = (ActiveCell.Column - CCE_FIRST_FORM_FIRST_COL) \ lenght + 1
    
    Dim taskCell As Range
    Set taskCell = sheetCCE.Range("CCE_" & curFormIndex & "_taskId")
    
    Dim answer As Integer
    
    answer = MsgBox("Вы действительно хотите удалить задание №" & taskCell.value & "?", vbQuestion + vbYesNo, "Подтверждение")
    
    If answer = vbNo Then
        Exit Sub
    End If
    
    Dim comment As String
    comment = InputBox("Введите причину отмены:", "Окно ввода")
    
    Dim syncResult As String
    syncResult = SetTaskStatusOnly(taskCell.value, "CCE", "Отмена", comment)

    If InStr(1, syncResult, """ok"": true", vbTextCompare) > 0 Then
        With taskCell.MergeArea
            .Interior.ColorIndex = 3
            If .Locked = False Then
                .Locked = True
            End If
        End With
    End If
End Sub


Public Sub Cancel_CCE_Task_wrap()

    CallMacroEx _
        "cancelCurrentTaskCCE", _
        REFRESH_TASKS_AFTER, _
        "CCE"
    
End Sub
