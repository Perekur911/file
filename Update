CREATE TABLE IF NOT EXISTS OPOH_results (
    resultIdOPOH INTEGER PRIMARY KEY AUTOINCREMENT,

    taskId INTEGER,
    sampleCode TEXT NOT NULL,

    openDateTime TEXT,
    valveState TEXT,

    TColdOpen REAL,
    coldCompP REAL,
    coldPunit TEXT,
    coldPabs INTEGER,
    coldExpP REAL,
    coldOpenPMPaAbs REAL,

    THotOpen REAL,
    hotCompP REAL,
    hotPunit TEXT,
    hotPabs INTEGER,
    hotExpP REAL,
    hotOpenPMPaAbs REAL,

    openOperator TEXT,

    restorationP REAL,
    restorationPunit TEXT,
    restorationPabs INTEGER,
    restorationPMPaAbs REAL,
    restorationT REAL,
    restorationStartDateTime TEXT,
    restorationStartOperator TEXT,
    restorationEndDateTime TEXT,
    restorationEndOperator TEXT,

    typeSampler TEXT,
    numberSampler TEXT,

    transferP REAL,
    transferPunit TEXT,
    transferPabs INTEGER,
    transferPMPaAbs REAL,
    transferT REAL,
    transferVolume REAL,
    transferDateTime TEXT,
    transferOperator TEXT,

    phaseDrainDateTime TEXT,

    sncVolumeHC REAL,
    sncVolumeDM REAL,
    sncVolumeW REAL,

    flcVolumeHC REAL,
    flcVolumeDM REAL,
    flcVolumeW REAL,

    phaseDrainOperator TEXT,
    comment TEXT
);

CREATE UNIQUE INDEX IF NOT EXISTS ux_OPOH_results_sampleCode
    ON OPOH_results (sampleCode);
