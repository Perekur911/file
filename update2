Да. Взял структуру проверки из `Validate_GOR_Form`, а набор полей — из фактической структуры `SSF_results`: у SSF вместо GOR-оборудования используются `ssfEquipment`, две ловушки `m0Trap1...m1Trap2`, а среди полученных проб нет `TedlarBag`.  

Метод самостоятельный: дополнительные `SSF_AddError`, `SSF_IsBooleanLike` и другие хелперы создавать не нужно.

```vba
Private Function Validate_SSF_Form( _
    ByVal formIndex As Long _
) As Boolean

    Validate_SSF_Form = False

    Dim wb As Workbook
    Set wb = ActiveWorkbook

    Dim sheetSSF As Worksheet
    Set sheetSSF = wb.Worksheets("SSF")

    Dim SSFTable As ListObject
    Set SSFTable = wb.Worksheets("SSF_results") _
                     .ListObjects("SSF_results")

    Dim errors As String
    Dim errorCount As Long

    If formIndex <= 0 Then
        MsgBox _
            "Некорректный номер формы SSF: " & formIndex, _
            vbExclamation
        Exit Function
    End If

    If Not NamedRangeExists( _
        wb, _
        "SSF_" & formIndex & "_sampleCode" _
    ) Then

        MsgBox _
            "Форма SSF_" & formIndex & " не найдена.", _
            vbExclamation
        Exit Function

    End If

    If Not ListObjectExists( _
        sheetSSF, _
        "SSF_source_" & formIndex _
    ) Then

        MsgBox _
            "Таблица SSF_source_" & formIndex & _
            " не найдена.", _
            vbExclamation
        Exit Function

    End If

    Dim headerCell As Range
    Dim fieldName As String
    Dim rangeName As String

    Dim rng As Range
    Dim valueText As String
    Dim fieldError As String

    Dim hasVialCount As Boolean
    Dim hasBottleCount As Boolean
    Dim hasPicsCount As Boolean
    Dim countFieldsSeen As Long

    For Each headerCell In SSFTable.HeaderRowRange.Cells

        fieldName = CStr(headerCell.Value)

        If fieldName = "dateTimeSync" Then
            GoTo next_header
        End If

        rangeName = _
            "SSF_" & formIndex & "_" & fieldName

        If Not NamedRangeExists(wb, rangeName) Then

            errorCount = errorCount + 1

            errors = errors & errorCount & _
                     ". Не найден именованный диапазон: " & _
                     rangeName & vbCrLf

            GoTo next_header

        End If

        Set rng = sheetSSF.Range(rangeName)

        If IsError(rng.Value) Then

            errorCount = errorCount + 1

            errors = errors & errorCount & _
                     ". " & rangeName & _
                     " содержит ошибку Excel: " & _
                     rng.Text & _
                     " (" & rng.Worksheet.Name & _
                     "!" & rng.Address(False, False) & ")" & _
                     vbCrLf

            GoTo next_header

        End If

        valueText = Trim$(CStr(rng.Value))
        fieldError = ""

        Select Case fieldName

            Case "resultIdSSF"

                ' До первого сохранения может быть пустым.


            Case "TaskId"

                If valueText <> "" Then

                    If Not IsNumeric(rng.Value) Then

                        fieldError = _
                            "Номер задания должен быть числом: " & _
                            rangeName

                    ElseIf CDbl(rng.Value) < 0 Then

                        fieldError = _
                            "Номер задания не может быть отрицательным: " & _
                            rangeName

                    End If

                End If


            Case "page"

                If valueText <> "" Then

                    If Not IsNumeric(rng.Value) Then

                        fieldError = _
                            "Номер страницы должен быть числом: " & _
                            rangeName

                    ElseIf CDbl(rng.Value) <= 0 Then

                        fieldError = _
                            "Номер страницы должен быть больше нуля: " & _
                            rangeName

                    ElseIf CDbl(rng.Value) <> Fix(CDbl(rng.Value)) Then

                        fieldError = _
                            "Номер страницы должен быть целым числом: " & _
                            rangeName

                    End If

                End If


            Case "sampleCode"

                If valueText = "" Then

                    fieldError = _
                        "Не заполнен шифр исходной пробы: " & _
                        rangeName

                End If


            Case "Correct"

                If valueText = "" Then

                    fieldError = _
                        "Не заполнено поле корректности расчёта: " & _
                        rangeName

                ElseIf VarType(rng.Value) <> vbBoolean Then

                    Select Case LCase$(valueText)

                        Case "true", "false", _
                             "истина", "ложь", _
                             "1", "0", _
                             "да", "нет", _
                             "+", "-"

                            ' Допустимое логическое значение.

                        Case Else

                            fieldError = _
                                "Поле корректности должно содержать " & _
                                "True/False: " & rangeName

                    End Select

                End If


            Case "dateStart"

                If valueText = "" Then

                    fieldError = _
                        "Не заполнена дата начала: " & _
                        rangeName

                ElseIf Not IsDate(rng.Value) Then

                    fieldError = _
                        "Дата начала должна быть датой: " & _
                        rangeName

                End If


            Case "dateEnd"

                If valueText = "" Then

                    fieldError = _
                        "Не заполнена дата окончания: " & _
                        rangeName

                ElseIf Not IsDate(rng.Value) Then

                    fieldError = _
                        "Дата окончания должна быть датой: " & _
                        rangeName

                End If


            Case "timeStart"

                If valueText = "" Then

                    fieldError = _
                        "Не заполнено время начала: " & _
                        rangeName

                ElseIf Not rng.Text Like "##:##" _
                   And Not rng.Text Like "#:##" Then

                    fieldError = _
                        "Время начала должно быть временем: " & _
                        rangeName

                End If


            Case "timeEnd"

                If valueText = "" Then

                    fieldError = _
                        "Не заполнено время окончания: " & _
                        rangeName

                ElseIf Not rng.Text Like "##:##" _
                   And Not rng.Text Like "#:##" Then

                    fieldError = _
                        "Время окончания должно быть временем: " & _
                        rangeName

                End If


            Case "operator"

                If valueText = "" Then

                    fieldError = _
                        "Не указан исполнитель: " & _
                        rangeName

                ElseIf Not IsValidExecutor(rng.Value) Then

                    fieldError = _
                        "Неверно указан исполнитель: " & _
                        rangeName

                End If


            Case "analyseNumber"

                If valueText = "" Then

                    fieldError = _
                        "Не указан номер анализа: " & _
                        rangeName

                End If


            Case "equipmentForTransfer"

                If valueText = "" Then

                    fieldError = _
                        "Не указано оборудование переноса пробы: " & _
                        rangeName

                End If


            Case "equipForTransferNumber"

                If valueText = "" Then

                    fieldError = _
                        "Не указан номер оборудования переноса пробы: " & _
                        rangeName

                End If


            Case "ssfEquipment"

                If valueText = "" Then

                    fieldError = _
                        "Не указано оборудование SSF: " & _
                        rangeName

                End If


            Case "ssfEquipmentNumber"

                If valueText = "" Then

                    fieldError = _
                        "Не указан номер оборудования SSF: " & _
                        rangeName

                End If


            Case "Ppic"

                If valueText <> "" Then

                    If Not valueText Like "20##-P##" Then

                        fieldError = _
                            "Формат номера пикнометра должен быть " & _
                            "20##-P##: " & rangeName

                    End If

                End If


            Case "PtransferMPa"

                If valueText <> "" Then

                    If Not IsNumeric(rng.Value) Then

                        fieldError = _
                            "Давление переноса, МПа, должно быть числом: " & _
                            rangeName

                    ElseIf CDbl(rng.Value) < 0 Then

                        fieldError = _
                            "Давление переноса, МПа, " & _
                            "не может быть отрицательным: " & _
                            rangeName

                    End If

                End If


            Case "Ptransfer"

                If valueText <> "" Then

                    If Not IsNumeric(rng.Value) Then

                        fieldError = _
                            "Давление переноса должно быть числом: " & _
                            rangeName

                    ElseIf CDbl(rng.Value) < 0 Then

                        fieldError = _
                            "Давление переноса не может быть отрицательным: " & _
                            rangeName

                    End If

                End If


            Case "Tfact"

                If valueText = "" Then

                    fieldError = _
                        "Не указана фактическая температура: " & _
                        rangeName

                ElseIf Not IsNumeric(rng.Value) Then

                    fieldError = _
                        "Фактическая температура должна быть числом: " & _
                        rangeName

                ElseIf CDbl(rng.Value) < -20 _
                   Or CDbl(rng.Value) > 140 Then

                    fieldError = _
                        "Фактическая температура должна быть " & _
                        "от -20 до 140 °C: " & rangeName

                End If


            Case "T"

                If valueText <> "" Then

                    If Not IsNumeric(rng.Value) Then

                        fieldError = _
                            "Температура должна быть числом: " & _
                            rangeName

                    ElseIf CDbl(rng.Value) < -20 _
                       Or CDbl(rng.Value) > 140 Then

                        fieldError = _
                            "Температура должна быть " & _
                            "от -20 до 140 °C: " & rangeName

                    End If

                End If


            Case "VGTot"

                If valueText = "" Then

                    fieldError = _
                        "Не указан общий объём газа VGTot: " & _
                        rangeName

                ElseIf Not IsNumeric(rng.Value) Then

                    fieldError = _
                        "VGTot должен быть числом: " & _
                        rangeName

                ElseIf CDbl(rng.Value) <= 0 Then

                    fieldError = _
                        "VGTot должен быть больше нуля: " & _
                        rangeName

                End If


            Case "V1", _
                 "V2", _
                 "Patm", _
                 "circ2", _
                 "VHeTot", _
                 "VHeCyl", _
                 "VGCyl", _
                 "m0Trap1", _
                 "m1Trap1", _
                 "m0Trap2", _
                 "m1Trap2", _
                 "d20", _
                 "Vtransfer", _
                 "Vgas", _
                 "VgasSt", _
                 "mLiq", _
                 "VLiq", _
                 "GF"

                If valueText <> "" Then

                    If Not IsNumeric(rng.Value) Then

                        fieldError = _
                            fieldName & _
                            " должен быть числом: " & _
                            rangeName

                    ElseIf CDbl(rng.Value) < 0 Then

                        fieldError = _
                            fieldName & _
                            " не может быть отрицательным: " & _
                            rangeName

                    End If

                End If


            Case "deltaMatBalance", _
                 "AP"

                If valueText <> "" Then

                    If Not IsNumeric(rng.Value) Then

                        fieldError = _
                            fieldName & _
                            " должен быть числом: " & _
                            rangeName

                    End If

                End If


            Case "vial", _
                 "bottle", _
                 "pics"

                countFieldsSeen = countFieldsSeen + 1

                If valueText <> "" Then

                    If Not IsNumeric(rng.Value) Then

                        If valueText <> "-" Then

                            fieldError = _
                                "Количество " & fieldName & _
                                " должно быть целым числом или '-': " & _
                                rangeName

                        End If

                    ElseIf CDbl(rng.Value) < 0 Then

                        fieldError = _
                            "Количество " & fieldName & _
                            " не может быть отрицательным: " & _
                            rangeName

                    ElseIf CDbl(rng.Value) <> _
                           Fix(CDbl(rng.Value)) Then

                        fieldError = _
                            "Количество " & fieldName & _
                            " должно быть целым числом: " & _
                            rangeName

                    ElseIf CDbl(rng.Value) > 0 Then

                        Select Case fieldName

                            Case "vial"
                                hasVialCount = True

                            Case "bottle"
                                hasBottleCount = True

                            Case "pics"
                                hasPicsCount = True

                        End Select

                    End If

                End If

        End Select

        If fieldError <> "" Then

            errorCount = errorCount + 1

            errors = errors & errorCount & _
                     ". " & fieldError & vbCrLf

        End If

next_header:
    Next headerCell

    If countFieldsSeen = 3 Then

        If Not hasVialCount _
           And Not hasBottleCount _
           And Not hasPicsCount Then

            errorCount = errorCount + 1

            errors = errors & errorCount & _
                     ". Не указана ни одна полученная проба: " & _
                     "vial / bottle / pics." & vbCrLf

        End If

    End If

    If errorCount > 0 Then

        MsgBox _
            "SSF_" & formIndex & _
            " не сохранена. Исправьте ошибки:" & _
            vbCrLf & vbCrLf & errors, _
            vbExclamation

        Exit Function

    End If

    Validate_SSF_Form = True

End Function
```

В `Save_SSF` вызов нужно поставить после автоматического определения `analyseNumber`, но до `CheckSSFTask` и `CreateSampleCodeSSF3`:

```vba
If sheetSSF.Range("SSF_" & i & "_analyseNumber").Value = "" Then
    Call checkNumberAnalys2( _
        sheetSSF.Range("SSF_" & i & "_sampleCode").Value, _
        "SSF" _
    )
End If

If Not Validate_SSF_Form(i) Then
    Exit Function
End If

Dim curTask As Variant
curTask = sheetSSF.Range("SSF_" & i & "_TaskId").Value
```

То есть при ошибке одной заполненной формы весь `Save_SSF` вернёт оставленный по умолчанию `MACRO_FAILED`, и последующее обновление заданий не запустится.
