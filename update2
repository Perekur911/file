Private Function GetWorkingPythonExe() As String

    Dim candidates As Variant
    Dim pythonPath As Variant
    Dim shell As Object
    Dim process As Object
    Dim command As String

    candidates = Array( _
        Environ$("USERPROFILE") & _
            "\.venvs\sqlite-excel\Scripts\python.exe", _
        "L:\LRC\common_data\ФЛЮИДЫ\ГТИ\sqlite-excel" & _
            "\.venv\Scripts\python.exe" _
    )

    Set shell = CreateObject("WScript.Shell")

    For Each pythonPath In candidates

        If Len(Dir$(CStr(pythonPath))) > 0 Then

            On Error Resume Next

            command = """" & CStr(pythonPath) & """ --version"

            Set process = shell.Exec(command)

            If Err.Number = 0 Then

                Do While process.Status = 0
                    DoEvents
                Loop

                If process.ExitCode = 0 Then
                    GetWorkingPythonExe = CStr(pythonPath)
                    On Error GoTo 0
                    Exit Function
                End If

            End If

            Err.Clear
            Set process = Nothing
            On Error GoTo 0

        End If

    Next pythonPath

    Err.Raise _
        vbObjectError + 1001, _
        "GetWorkingPythonExe", _
        "Не найден рабочий интерпретатор Python."

End Function
