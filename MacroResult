## Проверка результата в `CallMacroCore`

```vba
Private Function CallMacroCore( _
    ByVal macroName As String, _
    ByVal hasMacroParam As Boolean, _
    ByVal macroParam As Variant, _
    ByVal refreshTasksMode As Long, _
    ByVal studies As Variant _
) As MacroResult

    CallMacroCore = MACRO_FAILED

    Dim wb As Workbook
    Set wb = ActiveWorkbook

    On Error GoTo CleanFail

    StartMacro wb, studies

    If refreshTasksMode = REFRESH_TASKS_BEFORE _
       Or refreshTasksMode = REFRESH_TASKS_BEFORE_AND_AFTER Then

        RefreshTasks_SelectFile

    End If

    Dim rawResult As Variant
    Dim macroResult As MacroResult

    If hasMacroParam Then

        rawResult = Application.Run( _
            macroName, _
            macroParam _
        )

    Else

        rawResult = Application.Run(macroName)

    End If

    macroResult = CLng(rawResult)

    Select Case macroResult

        Case MACRO_FAILED

            ' Никакие действия AFTER не выполняем.
            GoTo CleanExit


        Case MACRO_NO_CHANGES

            ' Всё прошло нормально, но обновлять задания незачем.
            CallMacroCore = MACRO_NO_CHANGES
            GoTo CleanExit


        Case MACRO_CHANGED

            If refreshTasksMode = REFRESH_TASKS_AFTER _
               Or refreshTasksMode = REFRESH_TASKS_BEFORE_AND_AFTER Then

                RefreshTasks_SelectFile

            End If

            CallMacroCore = MACRO_CHANGED


        Case Else

            Err.Raise _
                vbObjectError + 1000, _
                "CallMacroCore", _
                "Макрос " & macroName & _
                " вернул неизвестный результат: " & rawResult

    End Select

CleanExit:

    EndMacro wb, studies

    If HasAnyStudy(studies) Then
        wb.Worksheets(CStr(studies(0))).Activate
    End If

    Exit Function

CleanFail:

    Dim errNumber As Long
    Dim errSource As String
    Dim errDescription As String

    errNumber = Err.Number
    errSource = Err.Source
    errDescription = Err.Description

    On Error Resume Next
    EndMacro wb, studies
    On Error GoTo 0

    Err.Raise errNumber, errSource, errDescription

End Function
```

Получается нужное поведение:

* сохраняется только AP, но строк нет → `MACRO_NO_CHANGES`, задания не обновляются;
* запускается `Save_All`, но ни в одном исследовании строк нет → `MACRO_NO_CHANGES`, задания не обновляются;
* `Save_All`, хотя бы одно исследование сохранилось → `MACRO_CHANGED`, задания обновляются один раз после всего;
* где-то ошибка или не прошла валидация → `MACRO_FAILED`, сохранение останавливается, задания не обновляются.

Это как раз тот случай, где трёхсостоянийный результат намного чище и надёжнее, чем `Boolean`.
