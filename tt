CREATE TABLE IF NOT EXISTS CCE_results (
    resultIdCCE INTEGER PRIMARY KEY AUTOINCREMENT,

    TaskId INTEGER,
    sampleCode TEXT,
    PVTEqNumber TEXT,

    dateStart TEXT,
    dateEnd TEXT,
    operator TEXT,
    analyseNumber TEXT,

    Vres REAL,
    Vdew REAL,

    Pres REAL,
    Punit TEXT,
    PresMPa REAL,

    fluidMass REAL,
    fluidTransferDensity REAL,

    dateTimeSync TEXT
);

CREATE TABLE IF NOT EXISTS CCE_sourceData (
    rowIdCCE INTEGER PRIMARY KEY AUTOINCREMENT,
    resultIdCCE INTEGER NOT NULL,

    Pressure REAL,
    PressureMPa REAL,
    Phase INTEGER,

    Vcell REAL,
    Vliquid REAL,
    Vgas REAL,

    relativeCellVolume REAL,
    liquidVolumeFraction REAL,
    gasVolumeFraction REAL,

    monophaseDensity REAL,
    comment TEXT,
    active INTEGER,

    FOREIGN KEY (resultIdCCE)
        REFERENCES CCE_results(resultIdCCE)
        ON DELETE CASCADE
);

CREATE INDEX IF NOT EXISTS idx_CCE_results_sampleCode
ON CCE_results(sampleCode);

CREATE INDEX IF NOT EXISTS idx_CCE_results_taskId
ON CCE_results(TaskId);

CREATE INDEX IF NOT EXISTS idx_CCE_results_sampleCode_analyseNumber
ON CCE_results(sampleCode, analyseNumber);

CREATE INDEX IF NOT EXISTS idx_CCE_sourceData_resultIdCCE
ON CCE_sourceData(resultIdCCE);
