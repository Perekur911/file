Public Sub Save_CCE()

    Dim wb As Workbook
    Set wb = ActiveWorkbook

    Dim sheetCCE As Worksheet
    Set sheetCCE = wb.Worksheets("CCE")

    Dim sheetCCEResults As Worksheet
    Set sheetCCEResults = wb.Worksheets("CCE_results")

    Dim sheetCCESourceData As Worksheet
    Set sheetCCESourceData = wb.Worksheets("CCE_sourceData")

    Dim tasks As ListObject
    Set tasks = wb.Worksheets("Task").ListObjects(1)

    Dim CCETable As ListObject
    Set CCETable = sheetCCEResults.ListObjects("CCE_results")

    Dim CCESourceDataTable As ListObject
    Set CCESourceDataTable = sheetCCESourceData.ListObjects("CCE_sourceData")

    Dim parentRows As Collection
    Set parentRows = New Collection

    Dim childRows As Collection
    Set childRows = New Collection

    Dim oldSourceRowIds As Object
    Set oldSourceRowIds = BuildOldChildRowIdMap( _
        CCESourceDataTable, _
        COL_ROW_ID_DB, _
        COL_RESULT_ID_DB _
    )

    Dim i As Long
    Dim x As Long
    Dim formState As CCEFormState

    i = 1

    Do While NamedRangeExists(wb, "CCE_" & i & "_sampleCode")

        If sheetCCE.Range("CCE_" & i & "_TaskId").Interior.ColorIndex = 3 Then
            GoTo NextForm
        End If

        formState = Get_CCE_FormState(i)

        Select Case formState

            Case CCE_FORM_EMPTY
                GoTo NextForm

            Case CCE_FORM_RESERVED
                GoTo NextForm

            Case CCE_FORM_FILLED
                ' форма заполнена, идем дальше

        End Select

        If sheetCCE.Range("CCE_" & i & "_analyseNumber").value = "" Then
            Call checkNumberAnalys2(sheetCCE.Range("CCE_" & i & "_sampleCode").value, "CCE")
        End If

        If Not Validate_CCE_Form(i) Then
            Exit Sub
        End If

        Dim curTask As Variant
        curTask = sheetCCE.Range("CCE_" & i & "_TaskId").value

        If Len(Trim$(CStr(curTask))) > 0 And CLng(val(curTask)) <> 0 Then
            If Not CheckCCETask( _
                tasks, _
                CLng(val(curTask)), _
                CStr(sheetCCE.Range("CCE_" & i & "_sampleCode").value), _
                i _
            ) Then
                GoTo NextForm
            End If
        End If

        Dim resultIdValue As Variant
        Dim parentKey As String

        resultIdValue = sheetCCE.Range("CCE_" & i & "_resultIdCCE").value

        If Len(NormalizeKeyValue(resultIdValue)) = 0 Or NormalizeKeyValue(resultIdValue) = "0" Then
            parentKey = "temp_" & i
        Else
            parentKey = NormalizeKeyValue(resultIdValue)
        End If

        Dim parentRow() As Variant
        ReDim parentRow(1 To CCETable.ListColumns.count)

        Dim headerCell As Range
        Dim headerName As String
        Dim parentColIndex As Long
        Dim namedRangeName As String

        For Each headerCell In CCETable.HeaderRowRange.Cells

            headerName = CStr(headerCell.value)
            parentColIndex = CCETable.ListColumns(headerName).index

            If headerName = "dateTimeSync" Then
                parentRow(parentColIndex) = Format$(Now, "yyyy-mm-dd hh:nn:ss")

            ElseIf headerName = COL_RESULT_ID_DB Then
                parentRow(parentColIndex) = parentKey

            Else
                namedRangeName = "CCE_" & i & "_" & headerName

                If NamedRangeExists(wb, namedRangeName) Then
                    parentRow(parentColIndex) = FormatValueForSyncText( _
                        headerName, _
                        sheetCCE.Range(namedRangeName).value _
                    )
                End If
            End If

        Next headerCell

        parentRows.Add parentRow

        Dim srcTable As ListObject
        Set srcTable = sheetCCE.ListObjects("CCE_source_" & i)

        If SourceTableNeedsCompact( _
            srcTable, _
            Array(COL_PRESSURE_FORM, COL_VCELL_FORM), _
            Array("AND") _
        ) Then
            Call CompactSourceTable( _
                srcTable, _
                Array(COL_PRESSURE_FORM, COL_VCELL_FORM), _
                Array( _
                    COL_PRESSURE_FORM, _
                    COL_PRESSURE_MPA_FORM, _
                    COL_PHASE_FORM, _
                    COL_VCELL_FORM, _
                    COL_VLIQUID_FORM, _
                    COL_VGAS_FORM, _
                    COL_RELATIVE_CELL_VOLUME_FORM, _
                    COL_LIQUID_VOLUME_FRACTION_FORM, _
                    COL_GAS_VOLUME_FRACTION_FORM, _
                    COL_MONOPHASE_DENSITY_FORM, _
                    COL_COMMENT_FORM, _
                    COL_ACTIVE_FORM _
                ) _
            )
        End If

        Dim pressureCol As Long
        Dim pressureMPaCol As Long
        Dim phaseCol As Long
        Dim vcellCol As Long
        Dim vliquidCol As Long
        Dim vgasCol As Long
        Dim relativeCellVolumeCol As Long
        Dim liquidVolumeFractionCol As Long
        Dim gasVolumeFractionCol As Long
        Dim monophaseDensityCol As Long
        Dim commentCol As Long
        Dim activeCol As Long

        pressureCol = srcTable.ListColumns(COL_PRESSURE_FORM).index
        pressureMPaCol = srcTable.ListColumns(COL_PRESSURE_MPA_FORM).index
        phaseCol = srcTable.ListColumns(COL_PHASE_FORM).index
        vcellCol = srcTable.ListColumns(COL_VCELL_FORM).index
        vliquidCol = srcTable.ListColumns(COL_VLIQUID_FORM).index
        vgasCol = srcTable.ListColumns(COL_VGAS_FORM).index
        relativeCellVolumeCol = srcTable.ListColumns(COL_RELATIVE_CELL_VOLUME_FORM).index
        liquidVolumeFractionCol = srcTable.ListColumns(COL_LIQUID_VOLUME_FRACTION_FORM).index
        gasVolumeFractionCol = srcTable.ListColumns(COL_GAS_VOLUME_FRACTION_FORM).index
        monophaseDensityCol = srcTable.ListColumns(COL_MONOPHASE_DENSITY_FORM).index
        commentCol = srcTable.ListColumns(COL_COMMENT_FORM).index
        activeCol = srcTable.ListColumns(COL_ACTIVE_FORM).index

        For x = 1 To srcTable.ListRows.count

            Dim hasSourceData As Boolean
            Dim oldRowIdCCE As String

            hasSourceData = SourceRowHasData( _
                srcTable, _
                x, _
                Array(COL_PRESSURE_FORM, COL_VCELL_FORM), _
                Array("AND") _
            )

            oldRowIdCCE = GetOldChildRowId(oldSourceRowIds, parentKey, x)

            If hasSourceData Or Len(oldRowIdCCE) > 0 Then

                Dim childRow() As Variant
                ReDim childRow(1 To CCESourceDataTable.ListColumns.count)

                childRow(CCESourceDataTable.ListColumns(COL_ROW_ID_DB).index) = oldRowIdCCE
                childRow(CCESourceDataTable.ListColumns(COL_RESULT_ID_DB).index) = parentKey

                If hasSourceData Then

                    childRow(CCESourceDataTable.ListColumns(COL_PRESSURE_DB).index) = _
                        FormatValueForSyncText(COL_PRESSURE_DB, srcTable.DataBodyRange.Cells(x, pressureCol).value)

                    childRow(CCESourceDataTable.ListColumns(COL_PRESSURE_MPA_DB).index) = _
                        FormatValueForSyncText(COL_PRESSURE_MPA_DB, srcTable.DataBodyRange.Cells(x, pressureMPaCol).value)

                    childRow(CCESourceDataTable.ListColumns(COL_PHASE_DB).index) = _
                        FormatValueForSyncText(COL_PHASE_DB, srcTable.DataBodyRange.Cells(x, phaseCol).value)

                    childRow(CCESourceDataTable.ListColumns(COL_VCELL_DB).index) = _
                        FormatValueForSyncText(COL_VCELL_DB, srcTable.DataBodyRange.Cells(x, vcellCol).value)

                    childRow(CCESourceDataTable.ListColumns(COL_VLIQUID_DB).index) = _
                        FormatValueForSyncText(COL_VLIQUID_DB, srcTable.DataBodyRange.Cells(x, vliquidCol).value)

                    childRow(CCESourceDataTable.ListColumns(COL_VGAS_DB).index) = _
                        FormatValueForSyncText(COL_VGAS_DB, srcTable.DataBodyRange.Cells(x, vgasCol).value)

                    childRow(CCESourceDataTable.ListColumns(COL_RELATIVE_CELL_VOLUME_DB).index) = _
                        FormatValueForSyncText(COL_RELATIVE_CELL_VOLUME_DB, srcTable.DataBodyRange.Cells(x, relativeCellVolumeCol).value)

                    childRow(CCESourceDataTable.ListColumns(COL_LIQUID_VOLUME_FRACTION_DB).index) = _
                        FormatValueForSyncText(COL_LIQUID_VOLUME_FRACTION_DB, srcTable.DataBodyRange.Cells(x, liquidVolumeFractionCol).value)

                    childRow(CCESourceDataTable.ListColumns(COL_GAS_VOLUME_FRACTION_DB).index) = _
                        FormatValueForSyncText(COL_GAS_VOLUME_FRACTION_DB, srcTable.DataBodyRange.Cells(x, gasVolumeFractionCol).value)

                    childRow(CCESourceDataTable.ListColumns(COL_MONOPHASE_DENSITY_DB).index) = _
                        FormatValueForSyncText(COL_MONOPHASE_DENSITY_DB, srcTable.DataBodyRange.Cells(x, monophaseDensityCol).value)

                    childRow(CCESourceDataTable.ListColumns(COL_COMMENT_DB).index) = _
                        FormatValueForSyncText(COL_COMMENT_DB, srcTable.DataBodyRange.Cells(x, commentCol).value)

                    childRow(CCESourceDataTable.ListColumns(COL_ACTIVE_DB).index) = _
                        FormatValueForSyncText(COL_ACTIVE_DB, srcTable.DataBodyRange.Cells(x, activeCol).value)

                End If

                childRows.Add childRow

            End If

        Next x

NextForm:
        i = i + 1
    Loop

    WriteCollectionToListObject CCETable, parentRows
    WriteCollectionToListObject CCESourceDataTable, childRows

    If parentRows.count > 0 Then

        Dim syncResult As String
        syncResult = RunStudySync("save", studies:="CCE")

        If InStr(1, syncResult, """ok"": true", vbTextCompare) > 0 Then

            Call DeleteEmptyRowsByColumns( _
                CCESourceDataTable, _
                COL_ROW_ID_DB, _
                Array(COL_PRESSURE_DB, COL_VCELL_DB) _
            )

            Call Load_CCE_result_ids_to_forms

        Else
            MsgBox "Python-синхронизация CCE не подтвердила успешное сохранение." & vbCrLf & vbCrLf & _
                   syncResult, vbExclamation
        End If

    End If

    sheetCCE.Activate

End Sub


Private Sub Load_CCE_result_ids_to_forms()

    Dim wb As Workbook
    Set wb = ActiveWorkbook

    Dim sheetCCE As Worksheet
    Set sheetCCE = wb.Worksheets("CCE")

    Dim resultTable As ListObject
    Set resultTable = wb.Worksheets("CCE_results").ListObjects("CCE_results")

    If resultTable.DataBodyRange Is Nothing Then Exit Sub

    Dim resultRowIndex As Long
    Dim formIndex As Long

    For resultRowIndex = 1 To resultTable.ListRows.count

        formIndex = FindFormIndexForResultRow( _
            wb, _
            sheetCCE, _
            resultTable, _
            resultRowIndex, _
            "CCE", _
            Array("sampleCode", "analyseNumber") _
        )

        If formIndex > 0 Then
            Call CopyTableRowToNamedRanges( _
                wb, _
                sheetCCE, _
                resultTable, _
                resultRowIndex, _
                "CCE", _
                formIndex, _
                BuildFieldFilter("resultIdCCE") _
            )
        End If

    Next resultRowIndex

End Sub

Private Function CheckCCETask( _
    ByVal tasks As ListObject, _
    ByVal taskId As Long, _
    ByVal sampleCode As String, _
    ByVal pageNumber As Long _
) As Boolean

    CheckCCETask = False

    Dim taskCheck As Range
    Set taskCheck = tasks.ListColumns("Номер задания").DataBodyRange.Find( _
        What:=taskId, _
        LookAt:=xlWhole, _
        SearchOrder:=xlByColumns _
    )

    If taskCheck Is Nothing Then
        MsgBox "Указан неизвестный номер задания " & taskId & _
               " на странице " & pageNumber & _
               ". Данное исследование игнорируется, попробуйте обновить данные проекта или исправьте значение.", _
               vbExclamation
        Exit Function
    End If

    Dim taskRowIndex As Long
    taskRowIndex = taskCheck.row - tasks.DataBodyRange.row + 1

    If CStr(tasks.ListColumns("Код проекта").DataBodyRange.Cells(taskRowIndex, 1).value) <> sampleCode Then
        MsgBox "Указан неверный номер задания " & taskId & _
               " на странице " & pageNumber & _
               ". Шифр пробы в задании отличается от шифра пробы в исследовании. " & _
               "Данное исследование игнорируется, исправьте номер задания или выберите верную форму для внесения.", _
               vbExclamation
        Exit Function
    End If

    CheckCCETask = True

End Function

Public Sub Load_CCE_results_to_forms( _
    Optional ByVal mode As String = "by_key", _
    Optional ByVal fields As Variant _
)

    Dim wb As Workbook
    Set wb = ActiveWorkbook

    Dim sheetCCE As Worksheet
    Set sheetCCE = wb.Worksheets("CCE")

    Dim resultTable As ListObject
    Set resultTable = wb.Worksheets("CCE_results").ListObjects("CCE_results")

    Dim sourceTable As ListObject
    Set sourceTable = wb.Worksheets("CCE_sourceData").ListObjects("CCE_sourceData")

    Dim fieldFilter As Object
    Set fieldFilter = BuildFieldFilter(fields)

    mode = LCase$(Trim$(mode))

    If mode <> "by_key" And mode <> "sequential" Then
        Err.Raise vbObjectError + 6301, , "mode должен быть 'by_key' или 'sequential'"
    End If

    If resultTable.DataBodyRange Is Nothing Then
        MsgBox "Таблица CCE_results пустая.", vbInformation
        Exit Sub
    End If

    Dim resultRowIndex As Long
    Dim formIndex As Long
    Dim notFoundCount As Long

    For resultRowIndex = 1 To resultTable.ListRows.count

        If mode = "sequential" Then
            formIndex = resultRowIndex
            EnsureCCEFormExists wb, formIndex
        Else
            formIndex = FindFormIndexForResultRow( _
                wb, _
                sheetCCE, _
                resultTable, _
                resultRowIndex, _
                "CCE", _
                Array("sampleCode", "TaskId", "analyseNumber") _
            )
        End If

        If formIndex = 0 Or Not NamedRangeExists(wb, "CCE_" & formIndex & "_sampleCode") Then
            notFoundCount = notFoundCount + 1

            MsgBox "Не найдена форма для строки CCE_results #" & resultRowIndex & vbCrLf & _
                   "sampleCode = " & GetTableValue(resultTable, resultRowIndex, "sampleCode") & vbCrLf & _
                   "TaskId = " & GetTableValue(resultTable, resultRowIndex, "TaskId") & vbCrLf & _
                   "analyseNumber = " & GetTableValue(resultTable, resultRowIndex, "analyseNumber"), _
                   vbExclamation

            GoTo NextResultRow
        End If

        FillOneCCEFormFromResultRow _
            wb, _
            sheetCCE, _
            resultTable, _
            sourceTable, _
            resultRowIndex, _
            formIndex, _
            fieldFilter

NextResultRow:
    Next resultRowIndex

    If notFoundCount = 0 Then
        MsgBox "Данные CCE перенесены в формы.", vbInformation
    Else
        MsgBox "Данные CCE перенесены частично. Не найдено форм: " & notFoundCount, vbExclamation
    End If

End Sub

Private Sub EnsureCCEFormExists( _
    ByVal wb As Workbook, _
    ByVal formIndex As Long _
)

    Do While Not NamedRangeExists(wb, "CCE_" & formIndex & "_sampleCode")
        Call InsertListCCE2
    Loop

End Sub

Private Sub FillOneCCEFormFromResultRow( _
    ByVal wb As Workbook, _
    ByVal sheetCCE As Worksheet, _
    ByVal resultTable As ListObject, _
    ByVal sourceTable As ListObject, _
    ByVal resultRowIndex As Long, _
    ByVal formIndex As Long, _
    ByVal fieldFilter As Object _
)

    Dim resultId As Variant
    resultId = GetTableValue(resultTable, resultRowIndex, COL_RESULT_ID_DB)

    Call CopyTableRowToNamedRanges( _
        wb, _
        sheetCCE, _
        resultTable, _
        resultRowIndex, _
        "CCE", _
        formIndex, _
        fieldFilter _
    )

    If Len(Trim$(CStr(resultId))) > 0 Then
        FillCCESourceTableFromSourceData sheetCCE, sourceTable, formIndex, resultId, fieldFilter
    End If

End Sub

Private Sub FillCCESourceTableFromSourceData( _
    ByVal sheetCCE As Worksheet, _
    ByVal sourceTable As ListObject, _
    ByVal formIndex As Long, _
    ByVal resultId As Variant, _
    ByVal fieldFilter As Object _
)

    Dim formSourceTable As ListObject
    Set formSourceTable = sheetCCE.ListObjects("CCE_source_" & formIndex)

    If formSourceTable.DataBodyRange Is Nothing Then
        Exit Sub
    End If

    Call ClearMappedColumnsInTable( _
        formSourceTable, _
        CCESourceMappings(), _
        fieldFilter _
    )

    Call CopyMatchingTableRowsToTableRows( _
        sourceTable, _
        formSourceTable, _
        COL_RESULT_ID_DB, _
        resultId, _
        CCESourceMappings(), _
        fieldFilter _
    )

End Sub

Private Function CCESourceMappings() As Variant

    CCESourceMappings = Array( _
        Array(COL_PRESSURE_DB, COL_PRESSURE_FORM), _
        Array(COL_PRESSURE_MPA_DB, COL_PRESSURE_MPA_FORM), _
        Array(COL_PHASE_DB, COL_PHASE_FORM), _
        Array(COL_VCELL_DB, COL_VCELL_FORM), _
        Array(COL_VLIQUID_DB, COL_VLIQUID_FORM), _
        Array(COL_VGAS_DB, COL_VGAS_FORM), _
        Array(COL_RELATIVE_CELL_VOLUME_DB, COL_RELATIVE_CELL_VOLUME_FORM), _
        Array(COL_LIQUID_VOLUME_FRACTION_DB, COL_LIQUID_VOLUME_FRACTION_FORM), _
        Array(COL_GAS_VOLUME_FRACTION_DB, COL_GAS_VOLUME_FRACTION_FORM), _
        Array(COL_MONOPHASE_DENSITY_DB, COL_MONOPHASE_DENSITY_FORM), _
        Array(COL_COMMENT_DB, COL_COMMENT_FORM), _
        Array(COL_ACTIVE_DB, COL_ACTIVE_FORM) _
    )

End Function

