Private Const COL_PRESSURE_MPA_FORM As String = "Давление, МПа, изб."
Private Const COL_PHASE_FORM As String = "Фаза"
Private Const COL_VCELL_FORM As String = "Объем ячейки (Vcell), мл"
Private Const COL_VLIQUID_FORM As String = "Объем жидкости, мл"
Private Const COL_VGAS_FORM As String = "Объем газа, мл"
Private Const COL_RELATIVE_CELL_VOLUME_FORM As String = "Относительный объем ячейки, %"
Private Const COL_LIQUID_VOLUME_FRACTION_FORM As String = "Объемная доля жидкости, %"
Private Const COL_GAS_VOLUME_FRACTION_FORM As String = "Объемная доля газа, %"
Private Const COL_MONOPHASE_DENSITY_FORM As String = "Плотность в монофазе, г/см³"
Private Const COL_COMMENT_FORM As String = "Примечание"
Private Const COL_ACTIVE_FORM As String = "Активна"

