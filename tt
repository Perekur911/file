Private Const COL_PHASE_DB As String = "Phase"
Private Const COL_VCELL_DB As String = "Vcell"
Private Const COL_VLIQUID_DB As String = "Vliquid"
Private Const COL_VGAS_DB As String = "Vgas"
Private Const COL_RELATIVE_CELL_VOLUME_DB As String = "relativeCellVolume"
Private Const COL_LIQUID_VOLUME_FRACTION_DB As String = "liquidVolumeFraction"
Private Const COL_GAS_VOLUME_FRACTION_DB As String = "gasVolumeFraction"
Private Const COL_MONOPHASE_DENSITY_DB As String = "monophaseDensity"
Private Const COL_COMMENT_DB As String = "comment"
Private Const COL_ACTIVE_DB As String = "active"

