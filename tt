CREATE TABLE IF NOT EXISTS JOIN_results (
    resultIdJOIN INTEGER PRIMARY KEY AUTOINCREMENT,

    TaskId INTEGER,
    sampleCode TEXT NOT NULL,

    date TEXT,
    operator TEXT,

    equipment TEXT,
    equipmentNumber TEXT,

    preparationPressure REAL,
    absolutePressure REAL,
    pressureUnit TEXT,

    preparationTemperature REAL,
    preparationPressureMPa REAL,

    completeFWC INTEGER,

    dateTimeSync TEXT
);

CREATE TABLE IF NOT EXISTS JOIN_sourceData (
    rowIdJoin INTEGER PRIMARY KEY AUTOINCREMENT,
    resultIdJoin INTEGER NOT NULL,

    mixSampleCode TEXT,
    depleted INTEGER,

    FOREIGN KEY (resultIdJoin)
        REFERENCES JOIN_results(resultIdJOIN)
        ON DELETE CASCADE
);

CREATE INDEX IF NOT EXISTS idx_JOIN_results_TaskId
ON JOIN_results(TaskId);

CREATE INDEX IF NOT EXISTS idx_JOIN_results_sampleCode
ON JOIN_results(sampleCode);

CREATE INDEX IF NOT EXISTS idx_JOIN_results_sampleCode_TaskId
ON JOIN_results(sampleCode, TaskId);

CREATE INDEX IF NOT EXISTS idx_JOIN_sourceData_resultIdJoin
ON JOIN_sourceData(resultIdJoin);

CREATE INDEX IF NOT EXISTS idx_JOIN_sourceData_mixSampleCode
ON JOIN_sourceData(mixSampleCode);



