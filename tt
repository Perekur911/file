Private Function Validate_CCE_Form(ByVal formIndex As Long) As Boolean

    Validate_CCE_Form = False

    Dim wb As Workbook
    Set wb = ActiveWorkbook

    Dim sheetCCE As Worksheet
    Set sheetCCE = wb.Worksheets("CCE")

    Dim CCETable As ListObject
    Set CCETable = wb.Worksheets("CCE_results").ListObjects("CCE_results")

    Dim errors As String
    Dim errorCount As Long

    If formIndex <= 0 Then
        MsgBox "Некорректный номер формы CCE: " & formIndex, vbExclamation
        Exit Function
    End If

    If Not NamedRangeExists(wb, "CCE_" & formIndex & "_sampleCode") _
       Or Not ListObjectExists(sheetCCE, "CCE_source_" & formIndex) Then

        MsgBox "Форма CCE_" & formIndex & " не найдена.", vbExclamation
        Exit Function
    End If

    Dim headerCell As Range
    Dim fieldName As String
    Dim rangeName As String
    Dim rng As Range

    ' 1. Проверяем named ranges формы по колонкам CCE_results.
    For Each headerCell In CCETable.HeaderRowRange.Cells

        fieldName = CStr(headerCell.value)

        If fieldName = "dateTimeSync" Then
            GoTo next_header
        End If

        rangeName = "CCE_" & formIndex & "_" & fieldName

        If Not NamedRangeExists(wb, rangeName) Then

            errorCount = errorCount + 1
            errors = errors & errorCount & ". Не найден именованный диапазон: " & rangeName & vbCrLf
            GoTo next_header

        End If

        Set rng = sheetCCE.Range(rangeName)

        If IsError(rng.value) Then

            errorCount = errorCount + 1
            errors = errors & errorCount & ". " & rangeName & _
                     " содержит ошибку Excel: " & rng.text & _
                     " (" & rng.Worksheet.name & "!" & rng.Address(False, False) & ")" & vbCrLf
            GoTo next_header

        End If

        Select Case fieldName

            Case "resultIdCCE"
                ' Может быть пустым.

            Case "TaskId"
                If Trim$(CStr(rng.value)) <> "" Then
                    If Not IsNumeric(rng.value) Then
                        errorCount = errorCount + 1
                        errors = errors & errorCount & ". Номер задания должен быть числом: " & rangeName & vbCrLf
                    ElseIf CDbl(rng.value) < 0 Then
                        errorCount = errorCount + 1
                        errors = errors & errorCount & ". Номер задания не может быть отрицательным: " & rangeName & vbCrLf
                    End If
                End If

            Case "sampleCode"
                If Trim$(CStr(rng.value)) = "" Then
                    errorCount = errorCount + 1
                    errors = errors & errorCount & ". Не заполнен шифр пробы: " & rangeName & vbCrLf
                End If

            Case "PVTEqNumber"
                If Trim$(CStr(rng.value)) = "" Then
                    errorCount = errorCount + 1
                    errors = errors & errorCount & ". Не указан номер PVT-оборудования: " & rangeName & vbCrLf
                End If

            Case "dateStart"
                If Trim$(CStr(rng.value)) = "" Then
                    errorCount = errorCount + 1
                    errors = errors & errorCount & ". Не заполнена дата начала: " & rangeName & vbCrLf

                ElseIf Not IsDate(rng.value) Then
                    errorCount = errorCount + 1
                    errors = errors & errorCount & ". Введенное значение невозможно преобразовать в дату: " & rangeName & vbCrLf
                End If

            Case "dateEnd"
                If Trim$(CStr(rng.value)) = "" Then
                    errorCount = errorCount + 1
                    errors = errors & errorCount & ". Не заполнена дата окончания: " & rangeName & vbCrLf

                ElseIf Not IsDate(rng.value) Then
                    errorCount = errorCount + 1
                    errors = errors & errorCount & ". Введенное значение невозможно преобразовать в дату: " & rangeName & vbCrLf
                End If

            Case "operator"
                If Trim$(CStr(rng.value)) = "" Then
                    errorCount = errorCount + 1
                    errors = errors & errorCount & ". Не указан исполнитель: " & rangeName & vbCrLf

                ElseIf Not IsValidExecutor(rng.value) Then
                    errorCount = errorCount + 1
                    errors = errors & errorCount & ". Неверно указан исполнитель: " & rangeName & vbCrLf
                End If

            Case "analyseNumber"
                If Trim$(CStr(rng.value)) = "" Then
                    errorCount = errorCount + 1
                    errors = errors & errorCount & ". Не указан номер анализа: " & rangeName & vbCrLf
                End If

            Case "Vres", "Vdew"
                If Trim$(CStr(rng.value)) <> "" Then
                    If Not IsNumeric(rng.value) Then
                        errorCount = errorCount + 1
                        errors = errors & errorCount & ". Объем должен быть числом: " & rangeName & vbCrLf
                    ElseIf CDbl(rng.value) <= 0 Then
                        errorCount = errorCount + 1
                        errors = errors & errorCount & ". Объем должен быть больше 0: " & rangeName & vbCrLf
                    End If
                End If

            Case "Pres", "PresMPa"
                If Trim$(CStr(rng.value)) <> "" Then
                    If Not IsNumeric(rng.value) Then
                        errorCount = errorCount + 1
                        errors = errors & errorCount & ". Давление должно быть числом: " & rangeName & vbCrLf
                    ElseIf CDbl(rng.value) < 0 Then
                        errorCount = errorCount + 1
                        errors = errors & errorCount & ". Давление не может быть отрицательным: " & rangeName & vbCrLf
                    End If
                End If

            Case "Punit"
                If Trim$(CStr(rng.value)) = "" Then
                    errorCount = errorCount + 1
                    errors = errors & errorCount & ". Не указана единица давления: " & rangeName & vbCrLf
                End If

            Case "fluidMass", "fluidTransferDensity"
                If Trim$(CStr(rng.value)) <> "" Then
                    If Not IsNumeric(rng.value) Then
                        errorCount = errorCount + 1
                        errors = errors & errorCount & ". Значение должно быть числом: " & rangeName & vbCrLf
                    ElseIf CDbl(rng.value) <= 0 Then
                        errorCount = errorCount + 1
                        errors = errors & errorCount & ". Значение должно быть больше 0: " & rangeName & vbCrLf
                    End If
                End If

        End Select

next_header:
    Next headerCell

    ' 2. Проверяем таблицу CCE_source_N.
    Dim sourceTable As ListObject
    Set sourceTable = sheetCCE.ListObjects("CCE_source_" & formIndex)

    If Not ListColumnExists(sourceTable, COL_PRESSURE_FORM) _
       Or Not ListColumnExists(sourceTable, COL_PRESSURE_MPA_FORM) _
       Or Not ListColumnExists(sourceTable, COL_PHASE_FORM) _
       Or Not ListColumnExists(sourceTable, COL_VCELL_FORM) _
       Or Not ListColumnExists(sourceTable, COL_VLIQUID_FORM) _
       Or Not ListColumnExists(sourceTable, COL_VGAS_FORM) _
       Or Not ListColumnExists(sourceTable, COL_RELATIVE_CELL_VOLUME_FORM) _
       Or Not ListColumnExists(sourceTable, COL_LIQUID_VOLUME_FRACTION_FORM) _
       Or Not ListColumnExists(sourceTable, COL_GAS_VOLUME_FRACTION_FORM) _
       Or Not ListColumnExists(sourceTable, COL_MONOPHASE_DENSITY_FORM) _
       Or Not ListColumnExists(sourceTable, COL_COMMENT_FORM) _
       Or Not ListColumnExists(sourceTable, COL_ACTIVE_FORM) Then

        errorCount = errorCount + 1
        errors = errors & errorCount & ". В таблице CCE_source_" & formIndex & " не найдены обязательные столбцы." & vbCrLf
        GoTo after_source_validation
    End If

    If sourceTable.DataBodyRange Is Nothing Then
        errorCount = errorCount + 1
        errors = errors & errorCount & ". Таблица CCE_source_" & formIndex & " не содержит строк." & vbCrLf
        GoTo after_source_validation
    End If

    Dim pressureCol As Long
    Dim pressureMPaCol As Long
    Dim phaseCol As Long
    Dim vcellCol As Long
    Dim vliquidCol As Long
    Dim vgasCol As Long
    Dim relativeCellVolumeCol As Long
    Dim liquidVolumeFractionCol As Long
    Dim gasVolumeFractionCol As Long
    Dim monophaseDensityCol As Long
    Dim activeCol As Long

    pressureCol = sourceTable.ListColumns(COL_PRESSURE_FORM).index
    pressureMPaCol = sourceTable.ListColumns(COL_PRESSURE_MPA_FORM).index
    phaseCol = sourceTable.ListColumns(COL_PHASE_FORM).index
    vcellCol = sourceTable.ListColumns(COL_VCELL_FORM).index
    vliquidCol = sourceTable.ListColumns(COL_VLIQUID_FORM).index
    vgasCol = sourceTable.ListColumns(COL_VGAS_FORM).index
    relativeCellVolumeCol = sourceTable.ListColumns(COL_RELATIVE_CELL_VOLUME_FORM).index
    liquidVolumeFractionCol = sourceTable.ListColumns(COL_LIQUID_VOLUME_FRACTION_FORM).index
    gasVolumeFractionCol = sourceTable.ListColumns(COL_GAS_VOLUME_FRACTION_FORM).index
    monophaseDensityCol = sourceTable.ListColumns(COL_MONOPHASE_DENSITY_FORM).index
    activeCol = sourceTable.ListColumns(COL_ACTIVE_FORM).index

    Dim rowIndex As Long
    Dim pressureValue As Variant
    Dim pressureMPaValue As Variant
    Dim phaseValue As Variant
    Dim vcellValue As Variant
    Dim vliquidValue As Variant
    Dim vgasValue As Variant
    Dim relativeCellVolumeValue As Variant
    Dim liquidVolumeFractionValue As Variant
    Dim gasVolumeFractionValue As Variant
    Dim monophaseDensityValue As Variant
    Dim activeValue As Variant

    Dim pressureText As String
    Dim vcellText As String
    Dim phaseText As String

    Dim validRowsCount As Long
    Dim activeRowsCount As Long
    Dim isActive As Boolean

    For rowIndex = 1 To sourceTable.ListRows.count

        pressureValue = sourceTable.DataBodyRange.Cells(rowIndex, pressureCol).value
        pressureMPaValue = sourceTable.DataBodyRange.Cells(rowIndex, pressureMPaCol).value
        phaseValue = sourceTable.DataBodyRange.Cells(rowIndex, phaseCol).value
        vcellValue = sourceTable.DataBodyRange.Cells(rowIndex, vcellCol).value
        vliquidValue = sourceTable.DataBodyRange.Cells(rowIndex, vliquidCol).value
        vgasValue = sourceTable.DataBodyRange.Cells(rowIndex, vgasCol).value
        relativeCellVolumeValue = sourceTable.DataBodyRange.Cells(rowIndex, relativeCellVolumeCol).value
        liquidVolumeFractionValue = sourceTable.DataBodyRange.Cells(rowIndex, liquidVolumeFractionCol).value
        gasVolumeFractionValue = sourceTable.DataBodyRange.Cells(rowIndex, gasVolumeFractionCol).value
        monophaseDensityValue = sourceTable.DataBodyRange.Cells(rowIndex, monophaseDensityCol).value
        activeValue = sourceTable.DataBodyRange.Cells(rowIndex, activeCol).value

        If IsError(pressureValue) Then
            errorCount = errorCount + 1
            errors = errors & errorCount & ". CCE_source_" & formIndex & ", строка " & rowIndex & _
                     ": давление содержит ошибку Excel: " & sourceTable.DataBodyRange.Cells(rowIndex, pressureCol).text & vbCrLf
            GoTo next_source_row
        End If

        If IsError(vcellValue) Then
            errorCount = errorCount + 1
            errors = errors & errorCount & ". CCE_source_" & formIndex & ", строка " & rowIndex & _
                     ": объем ячейки содержит ошибку Excel: " & sourceTable.DataBodyRange.Cells(rowIndex, vcellCol).text & vbCrLf
            GoTo next_source_row
        End If

        pressureText = Trim$(CStr(pressureValue))
        vcellText = Trim$(CStr(vcellValue))

        If pressureText = "" Or vcellText = "" Then
            GoTo next_source_row
        End If

        validRowsCount = validRowsCount + 1

        If Not IsNumeric(pressureValue) Then
            errorCount = errorCount + 1
            errors = errors & errorCount & ". CCE_source_" & formIndex & ", строка " & rowIndex & _
                     ": давление должно быть числом." & vbCrLf
        ElseIf CDbl(pressureValue) < 0 Or CDbl(pressureValue) >= 14000 Then
            errorCount = errorCount + 1
            errors = errors & errorCount & ". CCE_source_" & formIndex & ", строка " & rowIndex & _
                     ": давление должно быть >= 0 и < 14000." & vbCrLf
        End If

        If IsError(pressureMPaValue) Then
            errorCount = errorCount + 1
            errors = errors & errorCount & ". CCE_source_" & formIndex & ", строка " & rowIndex & _
                     ": давление, МПа, содержит ошибку Excel." & vbCrLf
        ElseIf Trim$(CStr(pressureMPaValue)) <> "" Then
            If Not IsNumeric(pressureMPaValue) Then
                errorCount = errorCount + 1
                errors = errors & errorCount & ". CCE_source_" & formIndex & ", строка " & rowIndex & _
                         ": давление, МПа, должно быть числом." & vbCrLf
            ElseIf CDbl(pressureMPaValue) < 0 Then
                errorCount = errorCount + 1
                errors = errors & errorCount & ". CCE_source_" & formIndex & ", строка " & rowIndex & _
                         ": давление, МПа, не может быть отрицательным." & vbCrLf
            End If
        End If

        If IsError(phaseValue) Then
            errorCount = errorCount + 1
            errors = errors & errorCount & ". CCE_source_" & formIndex & ", строка " & rowIndex & _
                     ": фаза содержит ошибку Excel: " & sourceTable.DataBodyRange.Cells(rowIndex, phaseCol).text & vbCrLf
        Else
            phaseText = Trim$(CStr(phaseValue))

            If phaseText = "" Then
                errorCount = errorCount + 1
                errors = errors & errorCount & ". CCE_source_" & formIndex & ", строка " & rowIndex & _
                         ": не указана фаза." & vbCrLf
            ElseIf Not IsNumeric(phaseValue) Then
                errorCount = errorCount + 1
                errors = errors & errorCount & ". CCE_source_" & formIndex & ", строка " & rowIndex & _
                         ": фаза должна быть числом 1 или 2." & vbCrLf
            ElseIf CLng(phaseValue) <> 1 And CLng(phaseValue) <> 2 Then
                errorCount = errorCount + 1
                errors = errors & errorCount & ". CCE_source_" & formIndex & ", строка " & rowIndex & _
                         ": фаза должна быть 1 или 2." & vbCrLf
            End If
        End If

        If Not IsNumeric(vcellValue) Then
            errorCount = errorCount + 1
            errors = errors & errorCount & ". CCE_source_" & formIndex & ", строка " & rowIndex & _
                     ": объем ячейки должен быть числом." & vbCrLf
        ElseIf CDbl(vcellValue) <= 0 Then
            errorCount = errorCount + 1
            errors = errors & errorCount & ". CCE_source_" & formIndex & ", строка " & rowIndex & _
                     ": объем ячейки должен быть больше 0." & vbCrLf
        End If

        If IsError(vliquidValue) Then
            errorCount = errorCount + 1
            errors = errors & errorCount & ". CCE_source_" & formIndex & ", строка " & rowIndex & _
                     ": объем жидкости содержит ошибку Excel." & vbCrLf
        ElseIf Trim$(CStr(vliquidValue)) <> "" Then
            If Not IsNumeric(vliquidValue) Then
                errorCount = errorCount + 1
                errors = errors & errorCount & ". CCE_source_" & formIndex & ", строка " & rowIndex & _
                         ": объем жидкости должен быть числом." & vbCrLf
            ElseIf CDbl(vliquidValue) < 0 Then
                errorCount = errorCount + 1
                errors = errors & errorCount & ". CCE_source_" & formIndex & ", строка " & rowIndex & _
                         ": объем жидкости не может быть отрицательным." & vbCrLf
            End If
        End If

        If IsError(vgasValue) Then
            errorCount = errorCount + 1
            errors = errors & errorCount & ". CCE_source_" & formIndex & ", строка " & rowIndex & _
                     ": объем газа содержит ошибку Excel." & vbCrLf
        ElseIf Trim$(CStr(vgasValue)) <> "" Then
            If Not IsNumeric(vgasValue) Then
                errorCount = errorCount + 1
                errors = errors & errorCount & ". CCE_source_" & formIndex & ", строка " & rowIndex & _
                         ": объем газа должен быть числом." & vbCrLf
            ElseIf CDbl(vgasValue) < 0 Then
                errorCount = errorCount + 1
                errors = errors & errorCount & ". CCE_source_" & formIndex & ", строка " & rowIndex & _
                         ": объем газа не может быть отрицательным." & vbCrLf
            End If
        End If

        If IsError(relativeCellVolumeValue) Then
            errorCount = errorCount + 1
            errors = errors & errorCount & ". CCE_source_" & formIndex & ", строка " & rowIndex & _
                     ": относительный объем ячейки содержит ошибку Excel." & vbCrLf
        ElseIf Trim$(CStr(relativeCellVolumeValue)) <> "" Then
            If Not IsNumeric(relativeCellVolumeValue) Then
                errorCount = errorCount + 1
                errors = errors & errorCount & ". CCE_source_" & formIndex & ", строка " & rowIndex & _
                         ": относительный объем ячейки должен быть числом." & vbCrLf
            ElseIf CDbl(relativeCellVolumeValue) <= 0 Then
                errorCount = errorCount + 1
                errors = errors & errorCount & ". CCE_source_" & formIndex & ", строка " & rowIndex & _
                         ": относительный объем ячейки должен быть больше 0." & vbCrLf
            End If
        End If

        If IsError(liquidVolumeFractionValue) Then
            errorCount = errorCount + 1
            errors = errors & errorCount & ". CCE_source_" & formIndex & ", строка " & rowIndex & _
                     ": объемная доля жидкости содержит ошибку Excel." & vbCrLf
        ElseIf Trim$(CStr(liquidVolumeFractionValue)) <> "" Then
            If Not IsNumeric(liquidVolumeFractionValue) Then
                errorCount = errorCount + 1
                errors = errors & errorCount & ". CCE_source_" & formIndex & ", строка " & rowIndex & _
                         ": объемная доля жидкости должна быть числом." & vbCrLf
            ElseIf CDbl(liquidVolumeFractionValue) < 0 Or CDbl(liquidVolumeFractionValue) > 100 Then
                errorCount = errorCount + 1
                errors = errors & errorCount & ". CCE_source_" & formIndex & ", строка " & rowIndex & _
                         ": объемная доля жидкости должна быть от 0 до 100 %." & vbCrLf
            End If
        End If

        If IsError(gasVolumeFractionValue) Then
            errorCount = errorCount + 1
            errors = errors & errorCount & ". CCE_source_" & formIndex & ", строка " & rowIndex & _
                     ": объемная доля газа содержит ошибку Excel." & vbCrLf
        ElseIf Trim$(CStr(gasVolumeFractionValue)) <> "" Then
            If Not IsNumeric(gasVolumeFractionValue) Then
                errorCount = errorCount + 1
                errors = errors & errorCount & ". CCE_source_" & formIndex & ", строка " & rowIndex & _
                         ": объемная доля газа должна быть числом." & vbCrLf
            ElseIf CDbl(gasVolumeFractionValue) < 0 Or CDbl(gasVolumeFractionValue) > 100 Then
                errorCount = errorCount + 1
                errors = errors & errorCount & ". CCE_source_" & formIndex & ", строка " & rowIndex & _
                         ": объемная доля газа должна быть от 0 до 100 %." & vbCrLf
            End If
        End If

        If IsError(monophaseDensityValue) Then
            errorCount = errorCount + 1
            errors = errors & errorCount & ". CCE_source_" & formIndex & ", строка " & rowIndex & _
                     ": плотность в монофазе содержит ошибку Excel." & vbCrLf
        ElseIf Trim$(CStr(monophaseDensityValue)) <> "" Then
            If Not IsNumeric(monophaseDensityValue) Then
                errorCount = errorCount + 1
                errors = errors & errorCount & ". CCE_source_" & formIndex & ", строка " & rowIndex & _
                         ": плотность в монофазе должна быть числом." & vbCrLf
            ElseIf CDbl(monophaseDensityValue) <= 0 Then
                errorCount = errorCount + 1
                errors = errors & errorCount & ". CCE_source_" & formIndex & ", строка " & rowIndex & _
                         ": плотность в монофазе должна быть больше 0." & vbCrLf
            End If
        End If

        If IsError(activeValue) Then
            errorCount = errorCount + 1
            errors = errors & errorCount & ". CCE_source_" & formIndex & ", строка " & rowIndex & _
                     ": поле Активна содержит ошибку Excel: " & sourceTable.DataBodyRange.Cells(rowIndex, activeCol).text & vbCrLf
        Else
            isActive = False

            Select Case LCase$(Trim$(CStr(activeValue)))
                Case "true", "истина", "1", "yes", "да", "+"
                    isActive = True
            End Select

            If isActive Then
                activeRowsCount = activeRowsCount + 1
            End If
        End If

next_source_row:
    Next rowIndex

    If validRowsCount = 0 Then
        errorCount = errorCount + 1
        errors = errors & errorCount & ". В CCE_source_" & formIndex & _
                 " нет ни одной строки с заполненными давлением и объемом ячейки." & vbCrLf
    End If

    If activeRowsCount = 0 Then
        errorCount = errorCount + 1
        errors = errors & errorCount & ". В CCE_source_" & formIndex & _
                 " должна быть минимум 1 строка с Активна = True." & vbCrLf
    End If

after_source_validation:

    If errorCount > 0 Then
        MsgBox "CCE_" & formIndex & " не сохранена. Исправьте ошибки:" & vbCrLf & vbCrLf & errors, vbExclamation
        Exit Function
    End If

    Validate_CCE_Form = True

End Function

Private Function Get_CCE_FormState(ByVal formIndex As Long) As CCEFormState

    Dim sheetCCE As Worksheet
    Set sheetCCE = ActiveWorkbook.Worksheets("CCE")

    Dim sampleCode As String
    Dim taskId As String

    sampleCode = Trim$(CStr(sheetCCE.Range("CCE_" & formIndex & "_sampleCode").value))
    taskId = Trim$(CStr(sheetCCE.Range("CCE_" & formIndex & "_TaskId").value))

    Dim Vres As Variant
    Dim Vdew As Variant
    Dim Pres As Variant
    Dim PresMPa As Variant

    Vres = sheetCCE.Range("CCE_" & formIndex & "_Vres").value
    Vdew = sheetCCE.Range("CCE_" & formIndex & "_Vdew").value
    Pres = sheetCCE.Range("CCE_" & formIndex & "_Pres").value
    PresMPa = sheetCCE.Range("CCE_" & formIndex & "_PresMPa").value

    Dim valuesHaveError As Boolean
    valuesHaveError = IsError(Vres) Or IsError(Vdew) Or IsError(Pres) Or IsError(PresMPa)

    Dim valuesAreZero As Boolean

    If valuesHaveError Then
        valuesAreZero = False
    Else
        valuesAreZero = (val(Vres) = 0 And val(Vdew) = 0 And val(Pres) = 0 And val(PresMPa) = 0)
    End If

    Dim hasSampleCode As Boolean
    Dim hasValues As Boolean

    hasSampleCode = (sampleCode <> "")
    hasValues = Not valuesAreZero

    If Not hasSampleCode And Not hasValues Then
        Get_CCE_FormState = CCE_FORM_EMPTY
        Exit Function
    End If

    If hasSampleCode And hasValues Then
        Get_CCE_FormState = CCE_FORM_FILLED
        Exit Function
    End If

    Get_CCE_FormState = CCE_FORM_RESERVED

End Function

